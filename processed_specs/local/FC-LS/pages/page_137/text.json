      "span_index": 1
    },
    {
      "span_id": "p137_s0005",
      "text": "LS_RJT signifies rejection of the LKA request.",
      "bbox": [
        139.32,
        82.97,
        343.11,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p137_s0006",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        106.97,
        142.05,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0007",
      "text": "LS_ACC signifies that the connection is intact. The format of the LS_ACC payload is found",
      "bbox": [
        141.9,
        106.97,
        539.95,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 2
    },
