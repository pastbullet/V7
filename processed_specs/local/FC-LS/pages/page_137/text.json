      "span_index": 1
    },
    {
      "span_id": "p137_s0009",
      "text": "4.2.45",
      "bbox": [
        96.0,
        226.97,
        123.74,
        238.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0010",
      "text": "Define FFI Domain Topology Map (FFI_DTM)",
      "bbox": [
        133.8,
        226.97,
        343.71,
        238.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0011",
      "text": "4.2.45.1  Description",
      "bbox": [
        96.0,
        250.97,
        192.69,
        262.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0012",
      "text": "The FFI_DTM ELS Request shall transfer a complete initial or replacement Domain Topology Map to",
      "bbox": [
        96.0,
        274.96,
        539.92,
        286.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0013",
      "text": "the Domain Controller of the AE Principal Switch.",
      "bbox": [
        96.0,
        286.96,
        313.18,
        298.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0014",
      "text": "Support for this ELS is mandatory for a Domain Controller in an AE Principal Switch or an AE Switch",
      "bbox": [
        96.0,
        310.96,
        540.08,
        322.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0015",
      "text": "that is capable of becoming an AE Principal Switch. Support for this ELS is optional for Nx_Ports.",
      "bbox": [
        96.0,
        322.96,
        524.8,
        334.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0016",
      "text": "If the Domain Controller that receives an FFI_DTM request currently is not the AE Principal Switch, it",
      "bbox": [
        96.0,
        346.96,
        539.96,
        358.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0017",
      "text": "shall respond with an LS_RJT reply with a reason code of “Logical error”.",
      "bbox": [
        96.0,
        358.96,
        418.64,
        370.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0018",
      "text": "If a destination receives this ELS Request that is not a Domain Controller, it shall respond with an",
      "bbox": [
        96.0,
        382.96,
        539.82,
        394.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0019",
      "text": "LS_RJT reply with a reason code of “Command not supported”.",
      "bbox": [
        96.0,
        394.96,
        376.48,
        406.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0020",
      "text": "4.2.45.2  Protocol",
      "bbox": [
        96.0,
        418.96,
        178.28,
        430.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0021",
      "text": "a) FFI Domain Topology Map Request Sequence; and",
      "bbox": [
        106.02,
        442.96,
        350.68,
        454.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0022",
      "text": "b) LS_ACC or LS_RJT Reply Sequence.",
      "bbox": [
        106.02,
        466.96,
        290.73,
        478.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
