      "text": "Addressing:",
      "bbox": [
        96.0,
        514.96,
        155.35,
        526.08
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p137_s0025",
      "text": " The S_ID designates the Nx_Port sending an FFI Domain Topology Map. The D_ID",
      "bbox": [
        155.46,
        514.96,
        539.92,
        526.08
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p137_s0026",
      "text": "designates the Domain Controller of the AE Principal Switch in the form FFFCxxh, where xx is the",
      "bbox": [
        96.0,
        526.96,
        539.92,
        538.08
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p137_s0027",
