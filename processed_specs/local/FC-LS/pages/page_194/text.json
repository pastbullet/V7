      "text": ")* 2",
      "bbox": [
        344.52,
        190.97,
        360.01,
        202.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 5
    },
    {
      "span_id": "p194_s0016",
      "text": "(CS_Accuracy_Exponent-30)",
      "bbox": [
        360.06,
        186.49,
        484.32,
        197.21
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 6
    },
    {
      "span_id": "p194_s0017",
      "text": ",",
      "bbox": [
        484.32,
        190.97,
        487.09,
        202.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 7
    },
    {
      "span_id": "p194_s0018",
      "text": "where",
      "bbox": [
        120.0,
        214.97,
        147.19,
        226.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0019",
      "text": "a) T_reference is the clock reference value internal to the server ",
      "bbox": [
        106.02,
        238.97,
        396.87,
        250.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0020",
      "text": "b) CS_Accuracy_Mantissa is a value from 000b to 111b'",
      "bbox": [
        106.02,
        262.97,
        359.24,
        274.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0021",
      "text": "c)",
      "bbox": [
        106.02,
        286.96,
        114.34,
        298.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0022",
      "text": "CS_Accuracy_Exponent is a value from 00000b to 11111b'",
      "bbox": [
        122.37,
        286.96,
        383.69,
        298.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0023",
      "text": "Example #1, if CS_Accuracy Mantissa and Exponent are set to 001b and 01011b, respectively, the",
      "bbox": [
        96.0,
        310.96,
        539.85,
        322.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0024",
      "text": "Clock Synchronization value as it exits the server shall always be within the range of: ",
      "bbox": [
        96.0,
        322.96,
        473.73,
        334.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0025",
      "text": "T_reference ",
      "bbox": [
        120.0,
        346.96,
        176.66,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0026",
      "text": "± ",
      "bbox": [
        176.64,
        345.97,
        184.64,
        358.16
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p194_s0027",
      "text": "1,073 ",
      "bbox": [
        184.62,
        346.96,
        212.42,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p194_s0028",
      "text": "μ",
      "bbox": [
        212.4,
        345.97,
        218.14,
        358.16
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 4
    },
    {
      "span_id": "p194_s0029",
      "text": "sec",
      "bbox": [
        218.16,
        346.96,
        233.7,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 5
    },
    {
      "span_id": "p194_s0030",
      "text": "Example #2, if CS_Accuracy Mantissa and Exponent are set to 111b and 11000b, respectively, the",
      "bbox": [
        96.0,
        370.96,
        539.85,
        382.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0031",
      "text": "Clock Synchronization value as it exits the server shall always be within the range of:",
      "bbox": [
        96.0,
        382.96,
        470.99,
        394.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
