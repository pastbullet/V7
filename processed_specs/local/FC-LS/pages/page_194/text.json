      "span_id": "p194_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0002",
      "text": " 175",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0003",
      "text": "When sent to the Fabric during FLOGI, these bits indicate the accuracy that the Fabric is requested",
      "bbox": [
        96.0,
        57.65,
        539.97,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0004",
      "text": "to maintain in passing along to the clients the clock synchronization value it receives from the Clock",
      "bbox": [
        96.0,
        69.65,
        540.06,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0005",
      "text": "Synchronization Server (FFFFF6h).",
      "bbox": [
        96.0,
        81.65,
        253.14,
        92.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p194_s0006",
      "text": "When sent to the Clock Synchronization Server (FFFFF6h), these bits indicate the requested accura-",
      "bbox": [
        96.0,
        106.97,
        540.14,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0007",
      "text": "cy of the clock synchronization value as it leaves the server port.",
      "bbox": [
        96.0,
        118.97,
        380.94,
        130.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0008",
      "text": "When received from the Clock Synchronization Server (i.e., FFFFF6h), these bits indicate the accu-",
      "bbox": [
        96.0,
        142.96,
        540.06,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0009",
      "text": "racy of the clock synchronization value as it leaves the server port.  Specifically, the server shall sup-",
      "bbox": [
        96.0,
        154.96,
        540.08,
        166.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0010",
      "text": "ply a CS_Accuracy value such that the Clock Synchronization value is always within the range of:",
      "bbox": [
        96.0,
        166.96,
        525.9,
        178.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p194_s0011",
      "text": "T_reference ",
      "bbox": [
        120.0,
        190.96,
        176.66,
        202.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0012",
      "text": "±",
      "bbox": [
        176.64,
        189.97,
        182.1,
        202.16
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 2
    },
    {
