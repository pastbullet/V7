      "bbox": [
        184.62,
        406.96,
        236.26,
        418.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p194_s0035",
      "text": "6.6.9.1.4  Clock Synchronization Implemented MSB",
      "bbox": [
        96.0,
        430.96,
        337.64,
        442.08
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0036",
      "text": "The Clock Synchronization Implemented MSB field (word 62, bits 13 - 8) is a 6-bit value.  Word 62,",
      "bbox": [
        96.0,
        454.96,
        539.98,
        466.08
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0037",
      "text": "bits 15-14 are reserved and shall be set to zero.",
      "bbox": [
        96.0,
        466.96,
        307.61,
        478.08
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0038",
      "text": "When sent to the Clock Synchronization Server (i.e., FFFFF6h) during PLOGI, these bits indicate the",
      "bbox": [
        96.0,
        490.96,
        540.02,
        502.08
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0039",
      "text": "requested most significant bit position within the 64-bit Clock Count field in the CSU ELS Payload.",
      "bbox": [
        96.0,
        502.96,
        528.23,
        514.08
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0040",
      "text": "When received from the Clock Synchronization Server (i.e., FFFFF6h) this field represents the most",
      "bbox": [
        96.0,
        526.96,
        540.0,
        538.08
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0041",
      "text": "significant bit position within the 64-bit Clock Count field that contains meaningful information.",
      "bbox": [
        96.0,
        538.96,
        508.11,
        550.08
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0042",
      "text": "NOTE 20 – The value in the Clock Count field shall wrap around to zero when an overflow occurs from the",
      "bbox": [
        105.0,
        563.17,
        540.11,
        573.22
      ],
      "block_index": 19,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0043",
      "text": "Clock Synchronization Implemented MSB.",
      "bbox": [
        105.0,
        574.22,
        272.8,
        584.26
      ],
      "block_index": 19,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0044",
      "text": "(e.g., a value of 110111b indicates that the MSB of byte 1 of the Clock Count field is the highest bit",
      "bbox": [
        96.0,
        598.97,
        539.96,
        610.08
      ],
      "block_index": 20,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0045",
      "text": "that contains meaningful information).",
      "bbox": [
        96.0,
        610.97,
        262.67,
        622.08
      ],
      "block_index": 20,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p194_s0046",
      "text": "6.6.9.1.5  Clock Synchronization Implemented LSB",
      "bbox": [
        96.0,
        635.03,
        335.48,
        646.14
      ],
      "block_index": 21,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0047",
      "text": "The Clock Synchronization Implemented LSB field (word 62, bits 13 - 8) field is a 6-bit value.  Word",
      "bbox": [
        96.0,
        659.03,
        539.91,
        670.14
      ],
      "block_index": 22,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p194_s0048",
      "text": "62, bits 7-6 are reserved and shall be set to zero.",
      "bbox": [
        96.0,
        671.03,
        313.2,
        682.14
      ],
      "block_index": 22,
      "line_index": 2,
      "span_index": 1
    }
  ],
