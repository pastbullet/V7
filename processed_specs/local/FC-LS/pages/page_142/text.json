      "bbox": [
        96.0,
        298.97,
        139.27,
        310.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p142_s0007",
      "text": "LS_RJT signifies the rejection of the FFI_MUR Request. The LS_RJT reply contains an ap-",
      "bbox": [
        139.14,
        298.97,
        540.06,
        310.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p142_s0008",
      "text": "propriate reject reason code.",
      "bbox": [
        96.0,
        310.97,
        223.19,
        322.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p142_s0009",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        334.96,
        144.67,
        346.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p142_s0010",
      "text": "LS_ACC signifies acceptance of the FFI_MUR Request and registration to receive",
      "bbox": [
        145.32,
        334.96,
        539.96,
        346.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 2
    },
    {
