    {
      "span_id": "p106_s0009",
      "text": "4.2.30.1  Description",
      "bbox": [
        96.0,
        214.96,
        192.63,
        226.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p106_s0010",
      "text": "The NDACT ELS shall be sent to an Nx_Port by Alias Server (see FC-FS-2) to cause it to deactivate",
      "bbox": [
        96.0,
        238.96,
        540.06,
        250.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p106_s0011",
      "text": "the passed Alias_ID as an Alias_ID.",
      "bbox": [
        96.0,
        250.96,
        254.78,
        262.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
