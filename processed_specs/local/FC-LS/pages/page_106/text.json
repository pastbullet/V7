      "bbox": [
        96.0,
        370.96,
        157.1,
        382.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p106_s0017",
      "text": "The S_ID designates the Alias Server (FFFFF8h).  The D_ID field designates the",
      "bbox": [
        157.08,
        370.96,
        539.95,
        382.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 2
    },
    {
