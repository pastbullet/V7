      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0003",
      "text": "3.7.2",
      "bbox": [
        96.0,
        57.65,
        119.01,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0004",
      "text": "ignored: ",
      "bbox": [
        129.25,
        57.65,
        173.59,
        68.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0005",
      "text": "A keyword used to describe an unused bit, byte, word, field or code value. The",
      "bbox": [
        174.06,
        57.65,
        539.9,
        68.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0006",
      "text": "contents or value of an ignored bit, byte, word, field or code value shall not be examined by the",
      "bbox": [
        96.0,
        69.65,
        539.86,
        80.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0007",
      "text": "receiving device and may be set to any value by the transmitting device.",
      "bbox": [
        96.0,
        81.65,
        414.25,
        92.76
      ],
      "block_index": 3,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p034_s0008",
      "text": "3.7.3",
      "bbox": [
        96.0,
        106.97,
        118.63,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0009",
      "text": "invalid: ",
      "bbox": [
        128.7,
        106.97,
        167.29,
        118.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0010",
      "text": "A keyword used to describe an illegal or unsupported bit, byte, word, field or code",
      "bbox": [
        167.7,
        106.97,
        539.93,
        118.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0011",
      "text": "value. Receipt of an invalid bit, byte, word, field or code value shall be reported as an error.",
      "bbox": [
        96.0,
        118.97,
        498.21,
        130.08
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0012",
      "text": "3.7.4",
      "bbox": [
        96.0,
        142.96,
        118.63,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0013",
      "text": "mandatory: ",
      "bbox": [
        128.75,
        142.96,
        187.08,
        154.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0014",
      "text": "A keyword indicating an item that is required to be implemented as defined in",
      "bbox": [
        187.44,
        142.96,
        539.85,
        154.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0015",
      "text": "this standard.",
      "bbox": [
        96.0,
        154.96,
        155.96,
        166.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0016",
      "text": "3.7.5",
      "bbox": [
        96.0,
        178.96,
        118.53,
        190.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0017",
      "text": "may: ",
      "bbox": [
        128.65,
        178.96,
        155.05,
        190.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0018",
      "text": "A keyword that indicates flexibility of choice with no implied preference (equivalent to",
      "bbox": [
        155.46,
        178.96,
        539.88,
        190.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0019",
      "text": "\"may or may not\").",
      "bbox": [
        96.0,
        190.96,
        178.02,
        202.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0020",
      "text": "3.7.6",
      "bbox": [
        96.0,
        214.96,
        118.28,
        226.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0021",
      "text": "may not: ",
      "bbox": [
        128.34,
        214.96,
        173.07,
        226.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0022",
      "text": "A keyword that indicates flexibility of choice with no implied preference (equivalent",
      "bbox": [
        173.34,
        214.96,
        540.03,
        226.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0023",
      "text": "to \"may or may not\").",
      "bbox": [
        96.0,
        226.96,
        189.17,
        238.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0024",
      "text": "3.7.7",
      "bbox": [
        96.0,
        250.96,
        118.29,
        262.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0025",
      "text": "meaningful:",
      "bbox": [
        128.29,
        250.96,
        185.06,
        262.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0026",
      "text": " A control field or bit that shall be applicable and that shall be interpreted by the",
      "bbox": [
        185.04,
        250.96,
        539.97,
        262.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0027",
      "text": "recipient.",
      "bbox": [
        96.0,
        262.96,
        136.49,
        274.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0028",
      "text": "3.7.8",
      "bbox": [
        96.0,
        286.96,
        118.22,
        298.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0029",
      "text": "not meaningful:",
      "bbox": [
        128.23,
        286.96,
        203.17,
        298.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0030",
      "text": " A control field or bit that shall be ignored by the recipient.",
      "bbox": [
        203.16,
        286.96,
        457.63,
        298.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0031",
      "text": "3.7.9",
      "bbox": [
        96.0,
        310.96,
        118.21,
        322.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0032",
      "text": "obsolete: ",
      "bbox": [
        128.22,
        310.96,
        175.39,
        322.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0033",
      "text": "A keyword indicating that an item was defined in prior Fibre Channel standards but",
      "bbox": [
        175.38,
        310.96,
        539.95,
        322.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0034",
      "text": "has been removed from this standard.",
      "bbox": [
        96.0,
        322.96,
        264.32,
        334.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0035",
      "text": "3.7.10",
      "bbox": [
        96.0,
        346.96,
        123.75,
        358.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0036",
      "text": "optional: ",
      "bbox": [
        133.75,
        346.96,
        178.75,
        358.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0037",
      "text": "A keyword that describes features that are not required to be implemented by this",
      "bbox": [
        178.86,
        346.96,
        539.97,
        358.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0038",
      "text": "standard. However, if any optional feature defined by this standards is implemented, then it shall be",
      "bbox": [
        96.0,
        358.96,
        540.02,
        370.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0039",
      "text": "implemented as defined in this standard.",
      "bbox": [
        96.0,
        370.96,
        275.38,
        382.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p034_s0040",
      "text": "3.7.11",
      "bbox": [
        96.0,
        394.96,
        123.77,
        406.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0041",
      "text": "reserved: ",
      "bbox": [
        133.77,
        394.96,
        181.48,
        406.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0042",
      "text": "A keyword referring to bits, bytes, words, fields and code values that are set aside",
      "bbox": [
        181.32,
        394.96,
        539.94,
        406.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0043",
      "text": "for future standardization. A reserved bit, byte, word or field shall be set to zero, or in accordance with",
      "bbox": [
        96.0,
        406.96,
        539.96,
        418.08
      ],
      "block_index": 12,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0044",
      "text": "a future extension to this standard. Recipients are not required to check reserved bits, bytes, words",
      "bbox": [
        96.0,
        418.96,
        539.97,
        430.08
      ],
      "block_index": 12,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p034_s0045",
      "text": "or fields for zero values. Receipt of reserved code values in defined fields shall be reported as error.",
      "bbox": [
        96.0,
        430.96,
        537.0,
        442.08
      ],
      "block_index": 12,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p034_s0046",
      "text": "3.7.12",
      "bbox": [
        96.0,
        454.96,
        123.85,
        466.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0047",
      "text": "restricted: ",
      "bbox": [
        133.85,
        454.96,
        185.54,
        466.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0048",
      "text": "A keyword referring to bits, bytes, words, and fields that are set aside for use in",
      "bbox": [
        185.82,
        454.96,
        539.99,
        466.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0049",
      "text": "other Fibre Channel standards. A restricted bit, byte, word, or field shall be treated as a reserved bit,",
      "bbox": [
        96.0,
        466.96,
        540.04,
        478.08
      ],
      "block_index": 13,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0050",
      "text": "byte, word or field for the purposes of the requirements defined in this standard.",
      "bbox": [
        96.0,
        478.96,
        447.67,
        490.08
      ],
      "block_index": 13,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p034_s0051",
      "text": "3.7.13",
      "bbox": [
        96.0,
        502.96,
        123.83,
        514.07
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0052",
      "text": "shall: ",
      "bbox": [
        133.89,
        502.96,
        162.8,
        514.07
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0053",
      "text": "A keyword indicating a mandatory requirement. Designers are required to implement",
      "bbox": [
        163.08,
        502.96,
        540.08,
        514.07
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0054",
      "text": "all such mandatory requirements to ensure interoperability with other products that conform to this",
      "bbox": [
        96.0,
        514.96,
        540.02,
        526.07
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0055",
      "text": "standard.",
      "bbox": [
        96.0,
        526.96,
        137.67,
        538.07
      ],
      "block_index": 14,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p034_s0056",
      "text": "3.7.14",
      "bbox": [
        96.0,
        550.96,
        125.23,
        562.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0057",
      "text": "should: ",
      "bbox": [
        135.53,
        550.96,
        176.48,
        562.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0058",
      "text": "A keyword indicating flexibility of choice with a strongly preferred alternative;",
      "bbox": [
        177.06,
        550.96,
        540.05,
        562.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0059",
      "text": "equivalent to the phrase \"it is strongly recommended\".",
      "bbox": [
        96.0,
        562.96,
        334.67,
        574.07
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p034_s0060",
      "text": "3.7.15",
      "bbox": [
        96.0,
        586.96,
        123.74,
        598.07
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0061",
      "text": "x ",
      "bbox": [
        133.74,
        586.96,
        142.09,
        598.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0062",
      "text": "or",
      "bbox": [
        142.08,
        586.96,
        150.98,
        598.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p034_s0063",
      "text": " xx: ",
      "bbox": [
        151.02,
        586.96,
        171.01,
        598.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 3
    },
    {
      "span_id": "p034_s0064",
      "text": "The value of the bit or field is not relevant.",
      "bbox": [
        171.0,
        586.96,
        356.5,
        598.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 4
    },
    {
      "span_id": "p034_s0065",
      "text": "3.8",
      "bbox": [
        96.0,
        610.96,
        109.88,
        622.07
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0066",
      "text": "T10 Vendor ID fields",
      "bbox": [
        119.88,
        610.96,
        215.93,
        622.07
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0067",
      "text": "A T10 Vendor ID shall be a string of one to eight characters that is recorded in an informal list of Ven-",
      "bbox": [
        96.0,
        635.02,
        539.96,
        646.13
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0068",
      "text": "dor IDs maintained by INCITS Technical Committee T10 (see http://www.t10.org).",
      "bbox": [
        96.0,
        647.02,
        457.0,
        658.13
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p034_s0069",
      "text": "A field described as containing a T10 Vendor ID shall contain the first character of the T10 Vendor ID",
      "bbox": [
        96.0,
        671.02,
        540.02,
        682.13
      ],
      "block_index": 19,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p034_s0070",
      "text": "in the most significant byte of the field, and successive characters of the T10 Vendor ID in succes-",
      "bbox": [
        96.0,
        683.02,
        540.12,
        694.13
      ],
      "block_index": 19,
      "line_index": 2,
      "span_index": 1
    }
  ],
  "asset_ids": []
}