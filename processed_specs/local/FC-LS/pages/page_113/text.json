      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p113_s0002",
      "text": " 94",
      "bbox": [
        521.04,
        723.59,
        534.92,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p113_s0003",
      "text": "mon to all FC-4 Types at that image pair or Nx_Port pair. If byte 0 of the first word of a TPRLO",
      "bbox": [
        122.4,
        57.65,
        540.08,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p113_s0004",
      "text": "Logout Parameter page contains the value other than 00h, the TPRLO Logout Parameter page",
      "bbox": [
        122.4,
        69.65,
        539.99,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p113_s0005",
      "text": "contains logout parameters for the FC-4 TYPE indicated.",
      "bbox": [
        122.4,
        81.65,
        373.44,
        92.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p113_s0006",
      "text": "b)",
      "bbox": [
        106.02,
        106.97,
        114.91,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p113_s0007",
      "text": " TYPE code extension:",
      "bbox": [
        114.91,
        106.97,
        227.35,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p113_s0008",
      "text": " Reserved for future use.",
      "bbox": [
        227.34,
        106.97,
        337.27,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 3
    },
    {
