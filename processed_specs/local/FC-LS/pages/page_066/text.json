      "text": "b)",
      "bbox": [
        106.02,
        610.96,
        114.91,
        622.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p066_s0031",
      "text": " Payload Length:",
      "bbox": [
        114.91,
        610.96,
        200.24,
        622.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p066_s0032",
      "text": " This field is the length in bytes of the entire Payload, inclusive of the word 0.",
      "bbox": [
        200.22,
        610.96,
        540.07,
        622.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p066_s0033",
      "text": "This value shall be a multiple of 4 bytes.  The minimum value of this field is 8 bytes.  The maxi-",
      "bbox": [
        122.4,
        622.96,
        539.98,
        634.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p066_s0034",
      "text": "mum value of this field is 1024 bytes.",
      "bbox": [
        122.4,
        634.96,
        286.25,
        646.07
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p066_s0035",
      "text": "c)",
      "bbox": [
        106.02,
        659.02,
        114.38,
        670.13
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
