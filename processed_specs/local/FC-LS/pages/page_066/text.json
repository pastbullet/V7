      "bbox": [
        122.4,
        659.02,
        237.57,
        670.13
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p066_s0037",
      "text": "Each affected Port_ID page contains the ID of the Nx_Port, Fabric",
      "bbox": [
        241.26,
        659.03,
        540.0,
        670.14
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 3
    },
    {
      "span_id": "p066_s0038",
