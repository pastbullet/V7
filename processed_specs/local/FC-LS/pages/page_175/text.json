  "page": 175,
  "spans": [
    {
      "span_id": "p175_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0002",
      "text": " 156",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0003",
      "text": "a) a connect-request (SOF",
      "bbox": [
        106.02,
        57.65,
        229.04,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0004",
      "text": "c1",
      "bbox": [
        229.02,
        59.44,
        237.48,
        68.34
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p175_s0005",
      "text": "),",
      "bbox": [
        237.48,
        57.65,
        243.61,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p175_s0006",
      "text": "b) a Class 2 Data frame, or",
      "bbox": [
        106.02,
        82.97,
        230.71,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0007",
      "text": "c)",
      "bbox": [
        106.02,
        106.97,
        114.38,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0008",
      "text": "a Class 3 Data frame",
      "bbox": [
        122.4,
        106.97,
        216.25,
        118.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0009",
      "text": "The value shall be a multiple of four bytes.  Values less than 256 or greater than 2 112 are invalid.",
      "bbox": [
        96.0,
        130.97,
        540.06,
        142.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0010",
      "text": "An Fx_Port shall support a Data Field size of at least 256 bytes.",
      "bbox": [
        96.0,
        142.97,
        377.58,
        154.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0011",
      "text": "6.6.2.7  Total Concurrent Sequences",
      "bbox": [
        96.0,
        166.97,
        268.15,
        178.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0012",
      "text": "Total Concurrent Sequences field (word 2, bits 23 - 16) specifies the total number of Concurrent Se-",
      "bbox": [
        96.0,
        190.96,
        539.99,
        202.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0013",
      "text": "quences for all classes that the Nx_Port is capable of supporting as a Recipient.",
      "bbox": [
        96.0,
        202.96,
        449.33,
        214.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0014",
      "text": "The Total Concurrent Sequences specified by an Nx_Port shall be less than or equal to the sum of",
      "bbox": [
        96.0,
        226.96,
        539.89,
        238.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0015",
      "text": "the Concurrent Sequences supported on a Class by Class basis (e.g., an Nx_Port may specify that it",
      "bbox": [
        96.0,
        238.96,
        539.96,
        250.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0016",
      "text": "is capable of supporting ten Concurrent Sequences in Class 2 and ten Concurrent Sequences in",
      "bbox": [
        96.0,
        250.96,
        539.85,
        262.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p175_s0017",
      "text": "Class 3.  However, the total number of Concurrent Sequences when both Class 2 and 3 are open",
      "bbox": [
        96.0,
        262.96,
        539.85,
        274.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p175_s0018",
      "text": "may be fifteen).",
      "bbox": [
        96.0,
        274.96,
        164.88,
        286.08
      ],
      "block_index": 9,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p175_s0019",
      "text": "6.6.2.8  Relative offset by category",
      "bbox": [
        96.0,
        298.96,
        259.26,
        310.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0020",
      "text": "The relative offset by category field (word 2, bits 15 - 0) shall indicate on a bit-position basis, whether",
      "bbox": [
        96.0,
        322.96,
        540.02,
        334.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0021",
      "text": "or not relative offset shall be supported for the corresponding Information Category (e.g., if bit 14 = 1",
      "bbox": [
        96.0,
        334.96,
        540.07,
        346.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0022",
      "text": "and bit 2 = 1 and the others are set to zero, Information Category 1110b and 0010b frames shall be",
      "bbox": [
        96.0,
        346.96,
        540.02,
        358.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p175_s0023",
      "text": "capable of using relative offset as a Sequence Recipient or a Sequence Initiator).  See FC-FS-2 for",
      "bbox": [
        96.0,
        358.96,
        540.0,
        370.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p175_s0024",
      "text": "definition of the Information Category field.",
      "bbox": [
        96.0,
        370.96,
        283.88,
        382.08
      ],
      "block_index": 11,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p175_s0025",
      "text": "6.6.2.9  R_A_TOV",
      "bbox": [
        96.0,
        394.96,
        178.19,
        406.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0026",
      "text": "The R_A_TOV value shall be specified as a count of 1 ms increments.  Therefore, a value of",
      "bbox": [
        96.0,
        418.96,
        540.04,
        430.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0027",
      "text": "0000000Ah specifies a time period of 10 milliseconds.",
      "bbox": [
        96.0,
        430.96,
        334.23,
        442.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0028",
      "text": "6.6.2.10  E_D_TOV",
      "bbox": [
        96.0,
        454.96,
        183.17,
        466.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0029",
      "text": "When the E_D_TOV Resolution bit (word 1, bit 26) is set to zero, the E_D_TOV value shall be speci-",
      "bbox": [
        96.0,
        478.96,
        539.94,
        490.08
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0030",
      "text": "fied as a count of 1 millisecond increments.  When the E_D_TOV Resolution bit is set to one, the",
      "bbox": [
        96.0,
        490.96,
        539.97,
        502.08
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0031",
      "text": "E_D_TOV value shall be specified as a count of 1 nanosecond increments (e.g., based on the setting",
      "bbox": [
        96.0,
        502.96,
        540.03,
        514.08
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p175_s0032",
      "text": "of  the E_D_TOV Resolution bit, a value of 0000000Ah specifies a time period of either 10 millisec-",
      "bbox": [
        96.0,
        514.96,
        539.96,
        526.08
      ],
      "block_index": 15,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p175_s0033",
      "text": "onds or 10 nanoseconds).",
      "bbox": [
        96.0,
        526.96,
        211.55,
        538.07
      ],
      "block_index": 15,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p175_s0034",
      "text": "For PLOGI, the E_D_TOV value in the LS_ACC to the PLOGI shall be greater than or equal to the",
      "bbox": [
        96.0,
        550.96,
        540.08,
        562.07
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0035",
      "text": "value in the PLOGI.  The E_D_TOV value in the LS_ACC shall be the value used by each Nx_Port.",
      "bbox": [
        96.0,
        562.96,
        540.04,
        574.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0036",
      "text": "See FC-FS-2 for definition of E_D_TOV.",
      "bbox": [
        96.0,
        574.96,
        274.28,
        586.07
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p175_s0037",
      "text": "6.6.3",
      "bbox": [
        96.0,
        598.96,
        118.25,
        610.07
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0038",
      "text": "Port_Name",
      "bbox": [
        128.25,
        598.96,
        180.97,
        610.07
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0039",
      "text": "The Port_Name is an eight-byte field (words 5-6) that identifies an FC_Port. Each FC_Port shall pro-",
      "bbox": [
        96.0,
        622.96,
        540.1,
        634.07
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p175_s0040",
      "text": "vide a Name_Identifier that is unique within the Fibre Channel interaction space of the FC_Port. Bits",
      "bbox": [
        96.0,
        635.02,
        539.99,
        646.13
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p175_s0041",
      "text": "63-60 specify the format of the Name_Identifier. The formats are defined in FC-FS-2.",
      "bbox": [
        96.0,
        647.02,
        470.44,
        658.13
      ],
      "block_index": 18,
      "line_index": 3,
      "span_index": 1
    }
  ],
  "asset_ids": []
}