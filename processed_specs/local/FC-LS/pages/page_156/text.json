      "text": "a) in Class 1, the Originator has transmitted the ACK (EOF",
      "bbox": [
        106.02,
        238.96,
        370.16,
        250.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p156_s0016",
      "text": "t",
      "bbox": [
        370.14,
        240.76,
        372.36,
        249.66
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 2
    },
    {
