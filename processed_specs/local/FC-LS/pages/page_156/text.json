      "text": "The Originator of the FLOGI request considers Fabric Login to have ended when",
      "bbox": [
        96.0,
        214.96,
        452.66,
        226.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
