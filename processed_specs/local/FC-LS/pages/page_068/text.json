      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0010",
      "text": "LS_ACC signifies acceptance of the RSCN Request.  The format of the LS_ACC Payload",
      "bbox": [
        142.08,
        358.96,
        539.94,
        370.08
      ],
