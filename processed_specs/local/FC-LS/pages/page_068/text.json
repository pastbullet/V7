      "text": " Table 37 – Address Format",
      "bbox": [
        252.72,
        79.66,
        383.22,
        90.78
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0026",
      "text": "Format",
      "bbox": [
        281.64,
        101.62,
        315.51,
        112.74
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0027",
      "text": "Value",
      "bbox": [
        499.09,
        101.62,
        525.75,
        112.74
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0028",
      "text": "Port Address - Bytes 1, 2, and 3 of the affected Port_ID are valid, and indicate a single ",
      "bbox": [
        106.14,
        123.64,
        490.56,
        134.76
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0029",
      "text": "Nx_Port or service with a well-known address.",
      "bbox": [
        106.14,
        135.64,
        310.48,
        146.76
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0030",
      "text": "0",
      "bbox": [
        509.64,
        125.62,
        515.18,
        136.74
      ],
      "block_index": 17,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p068_s0031",
      "text": "Area Address Group - Bytes 1 and 2 of the affected Port_ID are valid, and indicates a ",
      "bbox": [
        106.14,
        157.66,
        486.06,
        168.78
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0032",
      "text": "group of addresses that encompass an Area of E_Port or Nx_Port addresses.  Byte 3 ",
      "bbox": [
        106.14,
        169.66,
        486.2,
        180.78
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0033",
      "text": "shall be zero.  Any links and ports within the area may be affected.",
      "bbox": [
        106.14,
        181.66,
        399.96,
        192.78
      ],
      "block_index": 18,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p068_s0034",
      "text": "1",
      "bbox": [
        509.64,
        159.64,
        515.18,
        170.76
      ],
      "block_index": 19,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0035",
      "text": "Domain Address Group - Byte 1 of the affected Port_ID is valid, and indicates a group of ",
      "bbox": [
        106.14,
        203.62,
        492.42,
        214.74
      ],
      "block_index": 20,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0036",
      "text": "addresses that encompass a Domain.  Bytes 2 and 3 shall be zero.  Any links and ports ",
      "bbox": [
        106.14,
        215.62,
        492.15,
        226.74
      ],
      "block_index": 20,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0037",
      "text": "within the domain may be affected.",
      "bbox": [
        106.14,
        227.62,
        260.58,
        238.74
      ],
      "block_index": 20,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p068_s0038",
      "text": "2",
      "bbox": [
        509.64,
        205.66,
        515.18,
        216.78
      ],
      "block_index": 21,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0039",
      "text": "Fabric Address Group - This format indicates a group of addresses that encompass the ",
      "bbox": [
        106.14,
        249.64,
        492.19,
        260.76
      ],
      "block_index": 22,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0040",
      "text": "entire Fabric of Nx_Port addresses.  Bytes 1, 2 and 3 shall be zero.  Any links and ports ",
      "bbox": [
        106.14,
        261.64,
        492.25,
        272.76
      ],
      "block_index": 22,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0041",
      "text": "within the area may be affected.",
      "bbox": [
        106.14,
        273.64,
        247.83,
        284.76
      ],
      "block_index": 22,
      "line_index": 3,
      "span_index": 1
    },
    {
