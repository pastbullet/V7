        490.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0013",
      "text": "State Change Registration (SCR)",
      "bbox": [
        133.74,
        478.96,
        289.27,
        490.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0014",
      "text": "4.2.19.1  Description",
      "bbox": [
        96.0,
        502.96,
        192.63,
        514.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0015",
      "text": "The SCR ELS requests the Fabric Controller or Nx_Port to add the Nx_Port that is sending the SCR",
      "bbox": [
        96.0,
        526.96,
        540.01,
        538.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0016",
      "text": "Request to the list of Nx_Ports registered to receive the RSCN ELS.",
      "bbox": [
        96.0,
        538.96,
        396.54,
        550.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0017",
      "text": "4.2.19.2  Protocol",
      "bbox": [
        96.0,
        562.96,
        178.22,
        574.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0018",
      "text": "a) State Change Registration Request Sequence",
      "bbox": [
        106.02,
        586.96,
        327.39,
        598.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0019",
      "text": "b) LS_ACC or LS_RJT Reply Sequence",
      "bbox": [
        106.02,
        610.96,
        287.89,
        622.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0020",
      "text": "4.2.19.3  Request Sequence",
      "bbox": [
        96.0,
        635.02,
        227.06,
        646.14
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0021",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        659.02,
        157.1,
        670.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p068_s0022",
      "text": "The S_ID designates the Nx_Port requesting registration for State Change Notification.",
      "bbox": [
        157.08,
        659.02,
        540.06,
        670.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p068_s0023",
      "text": "The D_ID designates either the Fabric Controller, FFFFFDh, or the address of the Nx_Port from",
      "bbox": [
        96.0,
        671.02,
        539.9,
        682.14
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p068_s0024",
      "text": "which RSCNs are desired.",
      "bbox": [
        96.0,
        683.02,
        213.15,
        694.14
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
