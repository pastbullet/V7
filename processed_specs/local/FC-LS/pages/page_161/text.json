      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p161_s0005",
      "text": "The frequency of N_Port Login is installation dependent based on the frequency of configuration",
      "bbox": [
        96.0,
        82.97,
        539.85,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p161_s0006",
      "text": "changes that may alter the N_Port_ID within an installation.  Service Parameters of other Nx_Ports",
      "bbox": [
        96.0,
        94.97,
        539.87,
        106.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p161_s0007",
      "text": "are retained until the next N_Port Login or until N_Port Logout (implicit or explicit) is performed.",
      "bbox": [
        96.0,
        106.97,
        515.98,
        118.08
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p161_s0008",
      "text": "6.3.5",
