      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0002",
      "text": " 9",
      "bbox": [
        523.86,
        723.59,
        532.16,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0003",
      "text": "3.2.102",
      "bbox": [
        96.0,
        57.65,
        129.79,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0004",
      "text": "Process_Associator: ",
      "bbox": [
        139.85,
        57.65,
        243.32,
        68.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0005",
      "text": "A value used in the Association_Header to identify a process or a",
      "bbox": [
        243.66,
        57.65,
        540.0,
        68.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0006",
      "text": "group of processes within a node.  Process_Associator is the mechanism a process uses to address",
      "bbox": [
        96.0,
        69.65,
        540.13,
        80.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0007",
      "text": "another communicating process.  Process_Associator is a generic reference to Originator",
      "bbox": [
        96.0,
        81.65,
        539.98,
        92.76
      ],
      "block_index": 3,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0008",
      "text": "Process_Associator and Responder Process_Associator (see FC-FS-2).",
      "bbox": [
        96.0,
        93.65,
        415.97,
        104.76
      ],
      "block_index": 3,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p028_s0009",
      "text": "3.2.103",
      "bbox": [
        96.0,
        118.97,
        129.33,
        130.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0010",
      "text": "Public NL_Port: ",
      "bbox": [
        139.33,
        118.97,
        217.09,
        130.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0011",
      "text": "An NL_Port that attempts a Fabric Login (see FC-AL-2).",
      "bbox": [
        217.08,
        118.97,
        464.34,
        130.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0012",
      "text": "3.2.104",
      "bbox": [
        96.0,
        142.96,
        132.05,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0013",
      "text": "random relative offset: ",
      "bbox": [
        142.53,
        142.96,
        264.1,
        154.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0014",
      "text": "The relationship specified between relative offset values",
      "bbox": [
        264.9,
        142.96,
        539.89,
        154.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0015",
      "text": "contained in frame (n) and frame (n+1) of an Information Category within a single Sequence.  For a",
      "bbox": [
        96.0,
        154.96,
        539.98,
        166.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0016",
      "text": "given Information Category I within a single Sequence, initial relative offset (ROI) value for a frame",
      "bbox": [
        96.0,
        166.96,
        539.84,
        178.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0017",
      "text": "(n+1) is unrelated to that of the previous frame (n) (see FC-FS-2).",
      "bbox": [
        96.0,
        178.96,
        385.7,
        190.08
      ],
      "block_index": 5,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p028_s0018",
      "text": "3.2.105",
      "bbox": [
        96.0,
        202.96,
        129.32,
        214.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0019",
      "text": "relative offset: ",
      "bbox": [
        139.32,
        202.96,
        210.36,
        214.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0020",
      "text": "The displacement, expressed in bytes, of the first byte of a Payload related",
      "bbox": [
        210.3,
        202.96,
        540.0,
        214.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0021",
      "text": "to an upper level defined origin for a given Information Category (see continuously increasing relative",
      "bbox": [
        96.0,
        214.96,
        539.97,
        226.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0022",
      "text": "offset, random relative offset and)(see FC-FS-2).",
      "bbox": [
        96.0,
        226.96,
        311.54,
        238.08
      ],
      "block_index": 6,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0023",
      "text": "3.2.106",
      "bbox": [
        96.0,
        250.96,
        129.32,
        262.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0024",
      "text": "relative offset space: ",
      "bbox": [
        139.32,
        250.96,
        241.62,
        262.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0025",
      "text": "A virtual address space defined by the sending upper level for a set",
      "bbox": [
        241.68,
        250.96,
        540.02,
        262.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0026",
      "text": "of information carried in one or more information units.",
      "bbox": [
        96.0,
        262.96,
        335.93,
        274.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0027",
      "text": "3.2.107",
      "bbox": [
        96.0,
        286.96,
        130.91,
        298.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0028",
      "text": "remote Fx_Port: ",
      "bbox": [
        141.21,
        286.96,
        224.82,
        298.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0029",
      "text": "Relative to an Nx_Port that is communicating through a Fabric to a",
      "bbox": [
        225.36,
        286.96,
        539.92,
        298.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0030",
      "text": "remote Nx_Port, the Fx_Port to which the remote Nx_Port is directly attached (see local Fx_Port).",
      "bbox": [
        96.0,
        298.96,
        527.02,
        310.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0031",
      "text": "3.2.108",
      "bbox": [
        96.0,
        322.96,
        129.8,
        334.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0032",
      "text": "Responder: ",
      "bbox": [
        139.92,
        322.96,
        199.11,
        334.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0033",
      "text": "The logical function in an Nx_Port responsible for supporting the Exchange",
      "bbox": [
        199.56,
        322.96,
        539.85,
        334.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0034",
      "text": "initiated by the Originator in another Nx_Port.",
      "bbox": [
        96.0,
        334.96,
        295.97,
        346.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0035",
      "text": "3.2.109",
      "bbox": [
        96.0,
        358.96,
        129.75,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0036",
      "text": "Responder Exchange_ID (RX_ID): ",
      "bbox": [
        139.87,
        358.96,
        305.35,
        370.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0037",
      "text": "An identifier assigned by a Responder to identify an",
      "bbox": [
        305.7,
        358.96,
        539.93,
        370.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0038",
      "text": "Exchange and meaningful only to the Responder.",
      "bbox": [
        96.0,
        370.96,
        314.89,
        382.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0039",
      "text": "3.2.110",
      "bbox": [
        96.0,
        394.96,
        129.74,
        406.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0040",
      "text": "Secured Hypertext Transfer Protocol: ",
      "bbox": [
        139.86,
        394.96,
        323.42,
        406.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0041",
      "text": "A protocol for communicating various formats of",
      "bbox": [
        323.76,
        394.96,
        539.99,
        406.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0042",
      "text": "text with embedded links and display controls used in combination with a subordinate protocol that",
      "bbox": [
        96.0,
        406.96,
        540.05,
        418.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0043",
      "text": "provides security features (see RFC 2818).",
      "bbox": [
        96.0,
        418.96,
        286.49,
        430.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0044",
      "text": "3.2.111",
      "bbox": [
        96.0,
        442.96,
        130.3,
        454.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0045",
      "text": "Sequence: ",
      "bbox": [
        140.48,
        442.96,
        195.25,
        454.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0046",
      "text": "A set of one or more Data frames with a common Sequence_ID (SEQ_ID),",
      "bbox": [
        195.72,
        442.96,
        540.0,
        454.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0047",
      "text": "transmitted unidirectionally from one Nx_Port to another Nx_Port with a corresponding response, if",
      "bbox": [
        96.0,
        454.96,
        540.04,
        466.08
      ],
      "block_index": 12,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0048",
      "text": "applicable, transmitted in response to each Data frame (see FC-FS-2).",
      "bbox": [
        96.0,
        466.96,
        407.58,
        478.08
      ],
      "block_index": 12,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0049",
      "text": "3.2.112",
      "bbox": [
        96.0,
        490.96,
        129.35,
        502.07
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0050",
      "text": "Sequence_ID (SEQ_ID): ",
      "bbox": [
        139.35,
        490.96,
        254.27,
        502.07
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0051",
      "text": "An identifier used to identify a Sequence  (see FC-FS-2).",
      "bbox": [
        254.28,
        490.96,
        505.39,
        502.07
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0052",
      "text": "3.2.113",
      "bbox": [
        96.0,
        514.96,
        129.7,
        526.07
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0053",
      "text": "Sequence Initiator: ",
      "bbox": [
        139.76,
        514.96,
        233.83,
        526.07
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0054",
      "text": "The Nx_Port that initiates a Sequence and transmits Data frames to",
      "bbox": [
        234.18,
        514.96,
        539.94,
        526.07
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0055",
      "text": "the destination Nx_Port (see FC-FS-2).",
      "bbox": [
        96.0,
        526.96,
        269.28,
        538.07
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0056",
      "text": "3.2.114",
      "bbox": [
        96.0,
        550.96,
        129.43,
        562.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0057",
      "text": "Sequence Recipient: ",
      "bbox": [
        139.43,
        550.96,
        240.97,
        562.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0058",
      "text": "The Nx_Port that receives Data frames from the Sequence Initiator",
      "bbox": [
        241.26,
        550.96,
        540.05,
        562.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0059",
      "text": "and, if applicable, transmits responses (i.e., Link_Control frames) to the Sequence Initiator (see FC-",
      "bbox": [
        96.0,
        562.96,
        540.08,
        574.07
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0060",
      "text": "FS-2).",
      "bbox": [
        96.0,
        574.96,
        123.73,
        586.07
      ],
      "block_index": 15,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0061",
      "text": "3.2.115",
      "bbox": [
        96.0,
        598.96,
        129.87,
        610.07
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0062",
      "text": "Sequence Status Block: ",
      "bbox": [
        139.93,
        598.96,
        259.03,
        610.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0063",
      "text": "A logical construct that tracks the status of a Sequence.  Both",
      "bbox": [
        259.38,
        598.96,
        539.92,
        610.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0064",
      "text": "the Sequence Initiator and the Sequence Recipient have a Sequence Status Block for each",
      "bbox": [
        96.0,
        610.96,
        539.97,
        622.07
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0065",
      "text": "concurrently active Sequence (see FC-FS-2).",
      "bbox": [
        96.0,
        622.96,
        296.47,
        634.07
      ],
      "block_index": 16,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p028_s0066",
      "text": "3.2.116",
      "bbox": [
        96.0,
        647.02,
        129.48,
        658.13
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0067",
      "text": "Simple Network Management Protocol: ",
      "bbox": [
        139.54,
        647.02,
        329.47,
        658.13
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0068",
      "text": "A protocol for communicating simply structured",
      "bbox": [
        329.76,
        647.02,
        539.95,
        658.13
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0069",
      "text": "management information.  It is in wide use in versions 1 and 2. (see RFC 1157, RFC 1901).",
      "bbox": [
        96.0,
        659.02,
        500.37,
        670.13
      ],
      "block_index": 17,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p028_s0070",
      "text": "3.2.117",
      "bbox": [
        96.0,
        683.02,
        129.98,
        694.13
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p028_s0071",
      "text": "Source_Identifier (S_ID): ",
      "bbox": [
        140.1,
        683.02,
        262.35,
        694.13
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p028_s0072",
      "text": "The address identifier used to indicate the source Nx_Port of",
      "bbox": [
        262.8,
        683.02,
        539.96,
        694.13
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p028_s0073",
      "text": "the transmitted frame (see FC-FS-2).",
      "bbox": [
        96.0,
        695.02,
        259.79,
        706.13
      ],
      "block_index": 18,
      "line_index": 3,
      "span_index": 1
    }
  ],
  "asset_ids": []
}