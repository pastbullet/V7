      "text": "none",
      "bbox": [
        96.0,
        370.96,
        118.21,
        382.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p146_s0028",
      "text": "4.3.4",
      "bbox": [
        96.0,
