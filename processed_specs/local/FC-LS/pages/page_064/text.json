      "text": "map format defined in FC-AL-2 for the Loop Initialization Loop Position (LILP) Sequence.  If",
      "bbox": [
        122.4,
        466.96,
        539.92,
        478.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p064_s0022",
      "text": "Byte 0 of the first word of the AL_PA position map is set to zero, then no AL_PA position map is",
      "bbox": [
        122.4,
        478.96,
        539.97,
        490.08
      ],
      "block_index": 6,
      "line_index": 4,
      "span_index": 1
    },
    {
