      "text": "available.  This field is valid only when the value in the Loop State field is Online.",
      "bbox": [
        122.4,
        490.96,
        478.46,
        502.08
      ],
      "block_index": 6,
      "line_index": 5,
      "span_index": 1
    },
    {
