      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p115_s0028",
      "text": "a value of 001000b indicates that the client requests that the lowest bit that contains meaning-",
      "bbox": [
        122.4,
        334.96,
        540.05,
        346.08
