        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p115_s0004",
      "text": "B) CS_Accuracy_Mantissa is a value from 000b to 111b; and",
      "bbox": [
        122.4,
        82.97,
        395.14,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p115_s0005",
      "text": "C) CS_Accuracy_Exponent is a value from 00000b to 11111b;",
      "bbox": [
        122.4,
        106.97,
        400.15,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
