      "bbox": [
        212.1,
        358.96,
        515.42,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0030",
      "text": "Transition P4:P5",
      "bbox": [
        96.0,
        385.66,
        175.29,
        396.78
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
