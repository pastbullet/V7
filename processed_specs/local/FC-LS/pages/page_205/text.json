      "text": "There is a different state for each Virtual Fabric negotiated to be used on the link. The state for Virtual",
      "bbox": [
        96.0,
        397.67,
        540.06,
        408.78
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0035",
      "text": "Fabric K is denoted P5",
      "bbox": [
        96.0,
        412.31,
        197.02,
        423.42
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p205_s0036",
      "text": "(k)",
      "bbox": [
        197.1,
        410.14,
        206.42,
        419.04
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 2
    },
    {
      "span_id": "p205_s0037",
      "text": ".",
      "bbox": [
        206.4,
        412.31,
        209.17,
        423.42
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 3
    },
    {
