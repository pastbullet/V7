        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0003",
      "text": "State P2: AUTH_ELS.",
      "bbox": [
        96.0,
        57.65,
        197.4,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0004",
      "text": " In this state an Authentication transaction shall be performed (see FC-SP). If",
      "bbox": [
        197.4,
        57.65,
        540.11,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0005",
      "text": "the FLOGI LS_ACC had the Virtual Fabrics bit set to one and the D_ID set to 000000h, then the",
      "bbox": [
        96.0,
        69.65,
        539.88,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0006",
      "text": "N_Port shall use the N_Port Controller WKA as S_ID, otherwise the N_Port shall use the assigned",
      "bbox": [
        96.0,
        81.65,
        539.85,
        92.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p205_s0007",
      "text": "Address Identifier as S_ID.",
      "bbox": [
        96.0,
        93.65,
        214.88,
        104.76
      ],
      "block_index": 3,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p205_s0008",
      "text": "State P3: N_Port.",
      "bbox": [
        96.0,
        118.97,
        184.69,
        130.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0009",
      "text": " The N_Port continues its operations. The N_Port may acquire additional",
      "bbox": [
        185.16,
        118.97,
        539.96,
        130.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0010",
      "text": "N_Port_IDs by following the N_Port_ID virtualization procedure.",
      "bbox": [
        96.0,
        130.97,
        377.6,
        142.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0011",
      "text": "Transition P1:P2.",
      "bbox": [
        96.0,
        154.96,
        179.77,
        166.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0012",
      "text": " Occurs when the FLOGI LS_ACC has the Security bit set to one. If the FLOGI",
      "bbox": [
        179.94,
        154.96,
        539.96,
        166.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0013",
      "text": "LS_ACC has also the Virtual Fabrics bit set to one and the D_ID set to 000000h, then the N_Port",
      "bbox": [
        96.0,
        166.96,
        540.08,
        178.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0014",
      "text": "shall use the N_Port Controller WKA as S_ID for the Authentication transaction performed in state",
      "bbox": [
        96.0,
        178.96,
        539.95,
        190.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p205_s0015",
      "text": "P2.",
      "bbox": [
        96.0,
        190.96,
        111.01,
        202.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p205_s0016",
      "text": "Transition P1:P3.",
      "bbox": [
        96.0,
        214.96,
        177.43,
        226.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0017",
      "text": " Occurs when the FLOGI LS_ACC has both the Security bit and the Virtual Fabrics",
      "bbox": [
        177.48,
        214.96,
        539.98,
        226.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0018",
      "text": "bit set to zero.",
      "bbox": [
        96.0,
        226.96,
        158.76,
        238.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0019",
      "text": "Transition P2:P3.",
      "bbox": [
        96.0,
        250.96,
        177.49,
        262.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0020",
      "text": " Occurs when the Authentication transaction performed in state P2 completes suc-",
      "bbox": [
        177.54,
        250.96,
        540.08,
        262.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0021",
      "text": "cessfully and the FLOGI LS_ACC had the Virtual Fabrics bit set to zero.",
      "bbox": [
        96.0,
        262.96,
        413.31,
        274.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0022",
      "text": "Transition P1:P4.",
      "bbox": [
        96.0,
        286.96,
        178.16,
        298.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0023",
      "text": " Occurs when the FLOGI LS_ACC has the Security bit set to zero and the Virtual",
      "bbox": [
        178.14,
        286.96,
        540.05,
        298.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0024",
      "text": "Fabrics bit set to one.",
      "bbox": [
        96.0,
        298.96,
        191.52,
        310.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p205_s0025",
      "text": "Transition P2:P4.",
      "bbox": [
        96.0,
        322.96,
        177.49,
        334.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p205_s0026",
      "text": " Occurs when the Authentication transaction performed in state P2 completes suc-",
      "bbox": [
        177.54,
        322.96,
        540.08,
        334.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0027",
      "text": "cessfully and the FLOGI LS_ACC had the Virtual Fabrics bit set to one.",
      "bbox": [
        96.0,
        334.96,
        410.52,
        346.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
