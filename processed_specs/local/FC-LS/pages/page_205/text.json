      "text": "(k)",
      "bbox": [
        175.32,
        383.44,
        185.12,
        392.34
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p205_s0032",
      "text": ".",
      "bbox": [
        185.1,
        385.67,
        187.87,
        396.78
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p205_s0033",
      "text": " Occurs when the EVFP processing determined that VFT tagging is performed.",
      "bbox": [
        187.92,
        385.67,
        540.0,
        396.78
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 4
    },
    {
