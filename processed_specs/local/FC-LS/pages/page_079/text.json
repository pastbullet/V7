    {
      "span_id": "p079_s0004",
      "text": "Test Process Login State (TPLS)",
      "bbox": [
        133.84,
        57.65,
        288.12,
        68.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p079_s0005",
      "text": "4.2.22.1  Description",
      "bbox": [
        96.0,
        82.97,
        192.63,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0006",
      "text": "The TPLS ELS is used to determine whether image pairs are established for the image pairs speci-",
      "bbox": [
        96.0,
        106.97,
        540.05,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0007",
      "text": "fied by the combination of the S_ID || Originator Process_Associator || D_ID || Responder",
      "bbox": [
        96.0,
        118.97,
        539.84,
        130.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p079_s0008",
      "text": "Process_Associator.  Upon receiving a TPLS Request, the receiving Nx_Port checks whether it has",
      "bbox": [
        96.0,
        130.97,
        540.01,
        142.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p079_s0009",
      "text": "an image pair established for each specified image.",
      "bbox": [
        96.0,
        142.96,
        323.82,
        154.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p079_s0010",
      "text": "TPLS verifies the Login state for the source Nx_Port at the destination Nx_Port.",
      "bbox": [
        96.0,
        166.96,
        447.01,
        178.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0011",
      "text": "The LS_ACC Reply Sequence confirms the successful completion of the TPLS function and indi-",
      "bbox": [
        96.0,
        190.96,
        540.11,
        202.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0012",
      "text": "cates whether or not an image pair is established for the source specified by the S_ID and image",
      "bbox": [
        96.0,
        202.96,
        540.02,
        214.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p079_s0013",
      "text": "pair(s) contained in the Payload.  The Payload of the LS_ACC Reply indicates the state of the image",
      "bbox": [
        96.0,
        214.96,
        540.0,
        226.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p079_s0014",
      "text": "pair.",
      "bbox": [
        96.0,
        226.96,
        115.44,
        238.08
      ],
      "block_index": 7,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p079_s0015",
      "text": "4.2.22.2  Protocol",
      "bbox": [
        96.0,
        250.96,
        178.22,
        262.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0016",
      "text": "a) Test Process Login State Request Sequence",
      "bbox": [
        106.02,
        274.96,
        321.82,
        286.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0017",
      "text": "b) LS_ACC or LS_RJT Reply Sequence",
      "bbox": [
        106.02,
        298.96,
        287.89,
        310.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0018",
      "text": "4.2.22.3  Request Sequence",
      "bbox": [
        96.0,
        322.96,
        227.06,
        334.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0019",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        346.96,
        157.1,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p079_s0020",
      "text": "The S_ID field designates the source Nx_Port associated with the image pair.  The",
      "bbox": [
        157.08,
        346.96,
        540.06,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p079_s0021",
      "text": "D_ID field designates the destination Nx_Port associated with the image pair.",
      "bbox": [
        96.0,
        358.96,
        437.76,
        370.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
