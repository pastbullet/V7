  "spans": [
    {
      "span_id": "p208_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0002",
      "text": " 189",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0003",
      "text": "A) if the peer’s Port VF_ID is not equal to the local Port VF_ID, on completion of the Exchange",
      "bbox": [
        122.4,
        57.65,
        540.05,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0004",
      "text": "the EVFP protocol terminates and the EVFP Responder goes in Isolated state (transition",
      "bbox": [
        138.0,
        69.65,
        539.94,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0005",
      "text": "P4:P8, see 8.2); or",
      "bbox": [
        138.0,
        81.65,
        221.3,
        92.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0006",
      "text": "B) if the peer’s Port VF_ID is equal to the local Port VF_ID, on completion of the Exchange the",
      "bbox": [
        122.4,
        106.97,
        540.02,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0007",
      "text": "EVFP protocol terminates and the EVFP Responder goes in state P1 (transition P4:P1, see",
      "bbox": [
        138.0,
        118.97,
        540.05,
        130.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0008",
      "text": "8.2).",
      "bbox": [
        138.0,
        130.97,
        157.99,
        142.08
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0009",
      "text": "On receiving the EVFP_SYNC LS_ACC, the EVFP Initiator shall determine if VFT Tagging has",
      "bbox": [
        122.4,
        154.96,
        539.99,
        166.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0010",
      "text": "to be enabled on the link, according to table 126. If VFT Tagging has to be enabled, on comple-",
      "bbox": [
        122.4,
        166.96,
        540.06,
        178.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0011",
      "text": "tion of the Exchange the EVFP Initiator shall go to step 4. If VFT Tagging has not to be en-",
      "bbox": [
        122.4,
        178.96,
        540.12,
        190.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0012",
      "text": "abled, the EVFP Initiator disables the reception of VFT tagged frames and shall check the",
      "bbox": [
        122.4,
        190.96,
        540.01,
        202.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p208_s0013",
      "text": "received peer’s Port VF_ID:",
      "bbox": [
        122.4,
        202.96,
        245.15,
        214.08
      ],
      "block_index": 5,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p208_s0014",
      "text": "A) if the peer’s Port VF_ID is not equal to the local Port VF_ID, on completion of the Exchange",
      "bbox": [
        122.4,
        226.96,
        540.05,
        238.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0015",
      "text": "the EVFP protocol terminates and the EVFP Initiator goes in Isolated state (transition",
      "bbox": [
        138.0,
        238.96,
        539.9,
        250.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0016",
      "text": "P4:P8, see 8.2); or",
      "bbox": [
        138.0,
        250.96,
        221.3,
        262.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0017",
      "text": "B) if the peer’s Port VF_ID is equal to the local Port VF_ID, on completion of the Exchange the",
      "bbox": [
        122.4,
        274.96,
        540.02,
        286.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0018",
      "text": "EVFP protocol terminates and the EVFP Initiator goes in state P1 (transition P4:P1, see",
      "bbox": [
        138.0,
        286.96,
        539.9,
        298.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0019",
      "text": "8.2);",
      "bbox": [
        138.0,
        298.96,
        157.99,
        310.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0020",
      "text": "3) On completion of the EVFP_SYNC Exchange, the EVFP Responder shall enable both trans-",
      "bbox": [
        106.02,
        322.96,
        540.13,
        334.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0021",
      "text": "mission and reception of VFT tagged frames for the Virtual Fabrics operational on the link,",
      "bbox": [
        122.4,
        334.96,
        540.05,
        346.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0022",
      "text": "computed as explained in 4.2.56.2.4. Transmission and reception of VFT tagged frames for the",
      "bbox": [
        122.4,
        346.96,
        539.98,
        358.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0023",
      "text": "Control VF_ID shall be implicitly enabled. Transmission and reception of VFT tagged frames",
      "bbox": [
        122.4,
        358.96,
        540.01,
        370.08
      ],
      "block_index": 8,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p208_s0024",
      "text": "for the EVFP Initiator's Port VF_ID shall be also enabled on the link, to allow a successful com-",
      "bbox": [
        122.4,
        370.96,
        540.03,
        382.08
      ],
      "block_index": 8,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p208_s0025",
      "text": "pletion of the EVFP protocol. Then the EVFP Responder shall send an EVFP_COMMIT mes-",
      "bbox": [
        122.4,
        382.96,
        539.97,
        394.08
      ],
      "block_index": 8,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p208_s0026",
      "text": "sage (see 4.2.56.3), tagged with the EVFP Initiator's Port VF_ID; and",
      "bbox": [
        122.4,
        394.96,
        427.67,
        406.08
      ],
      "block_index": 8,
      "line_index": 7,
      "span_index": 1
    },
    {
      "span_id": "p208_s0027",
      "text": "4) On receiving the VFT tagged EVFP_COMMIT, the EVFP Initiator shall enable both transmis-",
      "bbox": [
        106.02,
        418.96,
        540.06,
        430.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0028",
      "text": "sion and reception of VFT tagged frames for the Virtual Fabrics operational on the link, comput-",
      "bbox": [
        122.4,
        430.96,
        539.99,
        442.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0029",
      "text": "ed as explained in 4.2.56.2.4. Transmission and reception of VFT tagged frames for the",
      "bbox": [
        122.4,
        442.96,
        539.98,
        454.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0030",
      "text": "Control VF_ID shall be implicitly enabled. Transmission and reception of VFT tagged frames",
      "bbox": [
        122.4,
        454.96,
        540.01,
        466.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p208_s0031",
      "text": "for the EVFP Initiator's Port VF_ID shall be also enabled on the link, to allow a successful com-",
      "bbox": [
        122.4,
        466.96,
        540.04,
        478.08
      ],
      "block_index": 9,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p208_s0032",
      "text": "pletion of the EVFP protocol. Then the EVFP Initiator shall send an EVFP_COMMIT LS_ACC",
      "bbox": [
        122.4,
        478.96,
        539.99,
        490.08
      ],
      "block_index": 9,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p208_s0033",
      "text": "message tagged with its Port VF_ID.",
      "bbox": [
        122.4,
        490.96,
        284.65,
        502.07
      ],
      "block_index": 9,
      "line_index": 7,
      "span_index": 1
    },
    {
      "span_id": "p208_s0034",
      "text": "When tagging is enabled the EVFP transaction completes successfully on completion of the",
      "bbox": [
        96.0,
        514.96,
        539.8,
        526.07
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0035",
      "text": "EVFP_COMMIT Exchange, for both the EVFP Initiator and EVFP Responder. If the computed set of",
      "bbox": [
        96.0,
        526.96,
        540.09,
        538.07
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0036",
      "text": "VF_IDs operational on the link does not include the EVFP Initiator's Port VF_ID, transmission and re-",
      "bbox": [
        96.0,
        538.96,
        540.0,
        550.07
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0037",
      "text": "ception of VFT tagged frames for such VF_ID shall be disabled on the link upon completion of the",
      "bbox": [
        96.0,
        550.96,
        539.8,
        562.07
      ],
      "block_index": 10,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p208_s0038",
      "text": "EVFP transaction. When the EVFP transaction is completed the processing continues independently",
      "bbox": [
        96.0,
        562.96,
        539.99,
        574.07
      ],
      "block_index": 10,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p208_s0039",
      "text": "for each Virtual Fabric operational on the link, as shown by transitions P4:P5(k) (see 8.2). If the com-",
      "bbox": [
        96.0,
        574.96,
        540.01,
        586.07
      ],
      "block_index": 10,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p208_s0040",
      "text": "puted set of VF_IDs operational on the link is NULL, the involved FC_Ports remain in state P4 (see",
      "bbox": [
        96.0,
        586.96,
        540.0,
        598.07
      ],
      "block_index": 10,
      "line_index": 7,
      "span_index": 1
    },
    {
      "span_id": "p208_s0041",
      "text": "8.2) until a new EVFP transaction is performed in the Control VF_ID.",
      "bbox": [
        96.0,
        598.96,
        398.7,
        610.07
      ],
      "block_index": 10,
      "line_index": 8,
      "span_index": 1
    },
    {
      "span_id": "p208_s0042",
      "text": "If an N_Port and an F_Port start an EVFP transaction at the same time, or if an FC_Port is acting as",
      "bbox": [
        96.0,
        622.96,
        540.13,
        634.07
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p208_s0043",
      "text": "an EVFP Initiator and receives an EVFP_SYNC message from the designated EVFP Responder,",
      "bbox": [
        96.0,
        635.02,
        539.98,
        646.13
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p208_s0044",
      "text": "one of the two EVFP transactions shall be aborted. The N_Port shall remain the EVFP Initiator, while",
      "bbox": [
        96.0,
        647.02,
        539.93,
        658.13
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p208_s0045",
      "text": "the F_Port shall become the EVFP Responder. The FC_Port that remains the EVFP Initiator shall re-",
      "bbox": [
        96.0,
        659.02,
        540.04,
        670.13
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p208_s0046",
      "text": "ply to the received EVFP_SYNC message with an ‘EVFP collision’ LS_RJT (see 4.2.43.1.2). The",
      "bbox": [
        96.0,
        671.02,
        539.71,
        682.13
      ],
      "block_index": 11,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p208_s0047",
      "text": "FC_Port that becomes the EVFP Responder shall reply to the received EVFP_SYNC message and",
      "bbox": [
        96.0,
        683.02,
        539.94,
        694.13
      ],
      "block_index": 11,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p208_s0048",
      "text": "abort its own transaction upon receipt of the LS_RJT.",
      "bbox": [
        96.0,
        695.02,
        331.5,
        706.13
      ],
      "block_index": 11,
      "line_index": 7,
      "span_index": 1
    }
  ],
  "asset_ids": []
}