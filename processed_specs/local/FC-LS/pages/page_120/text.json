        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0003",
      "text": "4.2.38.2  Protocol",
      "bbox": [
        96.0,
        57.65,
        178.22,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0004",
      "text": "a) Report node FC-4 Types (RNFT) Request sequence",
      "bbox": [
        106.02,
        82.97,
        354.5,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0005",
      "text": "b) LS_ACC or LS_RJT Reply Sequence",
      "bbox": [
        106.02,
        106.97,
        287.89,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0006",
      "text": "4.2.38.3  Request Sequence",
      "bbox": [
        96.0,
        130.97,
        227.06,
        142.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0007",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        154.96,
        157.1,
        166.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0008",
      "text": "The S_ID field designates the source Nx_Port requesting the FC-4 Types information.",
      "bbox": [
        157.08,
        154.96,
        540.03,
        166.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p120_s0009",
      "text": "The D_ID field designates the destination Nx_Port to which the request is being made.",
      "bbox": [
        96.0,
        166.96,
        477.62,
        178.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p120_s0010",
      "text": "Payload: ",
      "bbox": [
        96.0,
        190.96,
        140.41,
        202.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0011",
      "text": "The format of the request Payload is shown in table 104.",
      "bbox": [
        140.4,
        190.96,
        390.4,
        202.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p120_s0012",
      "text": "a)",
      "bbox": [
        106.02,
        310.96,
        114.91,
        322.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0013",
      "text": " Maximum Size:",
      "bbox": [
        114.91,
        310.96,
        194.78,
        322.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p120_s0014",
      "text": " Bytes 2-3 of Word 0 contain a 16-bit value that specifies the maximum length",
      "bbox": [
        194.76,
        310.96,
        540.0,
        322.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p120_s0015",
      "text": "of the RNFT LS_ACC that the originator is able to accept.  The value zero implies the RNFT",
      "bbox": [
        122.4,
        322.96,
        539.96,
        334.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p120_s0016",
      "text": "LS_ACC may be any size.",
      "bbox": [
        122.4,
        334.96,
        238.99,
        346.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p120_s0017",
      "text": "b)",
      "bbox": [
        106.02,
        358.96,
        114.91,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0018",
      "text": " Index:",
      "bbox": [
        114.91,
        358.96,
        151.84,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p120_s0019",
      "text": " Byte 3 of Word 1 contains an 8-bit value that specifies the index of the first FC-4 Entry to",
      "bbox": [
        151.8,
        358.96,
        540.01,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p120_s0020",
      "text": "be returned in the RNFT Reply.",
      "bbox": [
        122.4,
        370.96,
        261.25,
        382.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p120_s0021",
      "text": "Each FC-4 protocol supported by the responder has an index in the range from zero to (List",
      "bbox": [
        122.4,
        394.96,
        539.97,
        406.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p120_s0022",
      "text": "Length – 1) that should be used to specify a subset of the entries when the entire list does not",
      "bbox": [
        122.4,
        406.96,
        540.08,
        418.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p120_s0023",
      "text": "fit into one reply.  NOTE - The index of the entry for a particular FC-4 TYPE may not be consis-",
      "bbox": [
        122.4,
        418.96,
        540.05,
        430.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p120_s0024",
      "text": "tent between subsequent RNFT Requests (e.g., due to additions or deletions of supported FC-",
      "bbox": [
        122.4,
        430.96,
        540.11,
        442.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p120_s0025",
      "text": "4 TYPEs).",
      "bbox": [
        122.4,
        442.96,
        167.94,
        454.08
      ],
      "block_index": 11,
      "line_index": 5,
      "span_index": 1
    },
    {
