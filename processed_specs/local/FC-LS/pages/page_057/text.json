      "bbox": [
        96.0,
        671.02,
        157.1,
        682.13
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p057_s0036",
      "text": "The D_ID field designates the destination Nx_Port of the Exchange for which Se-",
      "bbox": [
        157.08,
        671.02,
        540.26,
        682.13
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p057_s0037",
      "text": "quence Initiative is being requested and the S_ID field designates the source Nx_Port that is request-",
      "bbox": [
        96.0,
        683.02,
        540.08,
        694.13
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
