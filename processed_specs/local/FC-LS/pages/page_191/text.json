      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0002",
      "text": " 172",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0003",
      "text": "6.6.7.4  Security Key Distribution Server",
      "bbox": [
        96.0,
        57.65,
        285.36,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0004",
      "text": "When set to one, the Security Key Distribution Server",
      "bbox": [
        96.0,
        82.97,
        331.16,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0005",
      "text": "bit (word 30, bit 8) shall indicate that the Fabric",
      "bbox": [
        333.84,
        82.97,
        540.03,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p191_s0006",
      "text": "supports routing to the well-known Key Distribution Server address identifier (FFFFF7h).  When set",
      "bbox": [
        96.0,
        94.97,
        539.99,
        106.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0007",
      "text": "to zero, this bit shall indicate that the Fabric does not support routing to the well-known Key Distribu-",
      "bbox": [
        96.0,
        106.97,
        540.02,
        118.08
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0008",
      "text": "tion Server address identifier.",
      "bbox": [
        96.0,
        118.97,
        225.92,
        130.08
      ],
      "block_index": 4,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p191_s0009",
      "text": "6.6.7.5  Alias Server",
      "bbox": [
        96.0,
        142.96,
        189.86,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0010",
      "text": "When set to one, the Alias Server",
      "bbox": [
        96.0,
        166.96,
        244.75,
        178.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0011",
      "text": "bit (word 30, bit 7) shall indicate that the Fabric supports routing to",
      "bbox": [
        247.5,
        166.96,
        539.9,
        178.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p191_s0012",
      "text": "the well-known Alias Server address identifier (FFFFF8h).  When set to zero, this bit shall indicate",
      "bbox": [
        96.0,
        178.96,
        539.89,
        190.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0013",
      "text": "that the Fabric does not support routing to the well-known Alias Server address identifier.",
      "bbox": [
        96.0,
        190.96,
        488.56,
        202.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0014",
      "text": "6.6.7.6  Management Server",
      "bbox": [
        96.0,
        214.96,
        227.06,
        226.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0015",
      "text": "When set to one, the Management Server bit (word 30, bit 5) shall indicate that the Fabric supports",
      "bbox": [
        96.0,
        238.96,
        539.95,
        250.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0016",
      "text": "routing to the well-known Management Server address identifier (i.e., FFFFFAh).  When set to zero,",
      "bbox": [
        96.0,
        250.96,
        540.0,
        262.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0017",
      "text": "this bit shall indicate that the Fabric does not support routing to the well-known Management Server",
      "bbox": [
        96.0,
        262.96,
        540.03,
        274.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0018",
      "text": "address identifier. See FC-GS-5 for the specification of this server.",
      "bbox": [
        96.0,
        274.96,
        389.97,
        286.08
      ],
      "block_index": 8,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p191_s0019",
      "text": "6.6.7.7  Time Server",
      "bbox": [
        96.0,
        298.96,
        189.35,
        310.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0020",
      "text": "When set to one, the Time Server bit (word 30, bit 4) shall indicate that the Fabric supports routing to",
      "bbox": [
        96.0,
        322.96,
        539.91,
        334.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0021",
      "text": "the well-known Time Server address identifier (i.e., FFFFFBh).  When set to zero, this bit shall indi-",
      "bbox": [
        96.0,
        334.96,
        540.0,
        346.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0022",
      "text": "cate that the Fabric does not support routing to the well-known Time Server address identifier.",
      "bbox": [
        96.0,
        346.96,
        510.95,
        358.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0023",
      "text": "6.6.7.8  Directory Server",
      "bbox": [
        96.0,
        370.96,
        209.85,
        382.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0024",
      "text": "When set to one, the Directory Server bit (word 30, bit 3) shall indicate that the Fabric supports rout-",
      "bbox": [
        96.0,
        394.96,
        539.99,
        406.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0025",
      "text": "ing to the well-known Directory Server address identifier (i.e., FFFFFCh).  When set to zero, this bit",
      "bbox": [
        96.0,
        406.96,
        540.05,
        418.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0026",
      "text": "shall indicate that the Fabric does not support routing to the well-known Directory Server address",
      "bbox": [
        96.0,
        418.96,
        540.05,
        430.08
      ],
      "block_index": 12,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0027",
      "text": "identifier. See FC-GS-5 for the specification of this server.",
      "bbox": [
        96.0,
        430.96,
        351.4,
        442.08
      ],
      "block_index": 12,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p191_s0028",
      "text": "6.6.8",
      "bbox": [
        96.0,
        454.96,
        118.23,
        466.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0029",
      "text": "Login Extension",
      "bbox": [
        128.23,
        454.96,
        205.94,
        466.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0030",
      "text": "6.6.8.1  General",
      "bbox": [
        96.0,
        478.96,
        169.33,
        490.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0031",
      "text": "If a port does not support a Login request with the Payload Bit set to one, the port shall reject the Lo-",
      "bbox": [
        96.0,
        502.96,
        539.96,
        514.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0032",
      "text": "gin request with an LS_RJT.  The reason code shall be set to \"Logical error\" with a reason code ex-",
      "bbox": [
        96.0,
        514.96,
        540.03,
        526.07
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0033",
      "text": "planation of \"Invalid Payload length\".",
      "bbox": [
        96.0,
        526.96,
        258.02,
        538.07
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0034",
      "text": "If a port does not support a Login request with a non-zero Login Extension Data Length field, the port",
      "bbox": [
        96.0,
        550.96,
        540.05,
        562.07
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0035",
      "text": "shall reject the Login request with an LS_RJT.  The reason code shall be set to \"Logical error\" with a",
      "bbox": [
        96.0,
        562.96,
        540.09,
        574.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0036",
      "text": "reason code explanation of \"Login Extension not supported\".",
      "bbox": [
        96.0,
        574.96,
        363.65,
        586.07
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0037",
      "text": "If a port receives a Login request containing a page code that it does not support, the port shall reject",
      "bbox": [
        96.0,
        598.96,
        540.09,
        610.07
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0038",
      "text": "the Login request with an LS_RJT.  The reason code shall be set to \"Logical error\" with a reason",
      "bbox": [
        96.0,
        610.96,
        540.02,
        622.07
      ],
      "block_index": 17,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p191_s0039",
      "text": "code explanation of \"Login Extension not supported\".",
      "bbox": [
        96.0,
        622.96,
        330.31,
        634.07
      ],
      "block_index": 17,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p191_s0040",
      "text": "If a port does not support a LS_ACC reply Sequence with the Payload Bit set to one, the port shall",
      "bbox": [
        96.0,
        647.02,
        540.02,
        658.13
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p191_s0041",
      "text": "perform an explicit Logout with the port that sent the reply.",
      "bbox": [
        96.0,
        659.02,
        353.19,
        670.13
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    }
  ],
  "asset_ids": []
}