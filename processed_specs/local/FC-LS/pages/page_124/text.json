      "bbox": [
        106.02,
        478.96,
        114.91,
        490.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p124_s0021",
      "text": " Error Window exponent and Error Window value:",
      "bbox": [
        114.91,
        478.96,
        357.78,
        490.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p124_s0022",
      "text": " The Error Window is a time duration de-",
      "bbox": [
        357.78,
        478.96,
        540.05,
        490.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p124_s0023",
      "text": "scribed by a 16-bit value.  Twelve bits, Bits 28-16, are used for the base value.  Four bits, Bits",
      "bbox": [
        122.4,
        490.96,
        540.03,
        502.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p124_s0024",
      "text": "31-28 are encoded to form the exponent.  The product of the base value and the exponent",
      "bbox": [
        122.4,
        502.96,
        539.96,
        514.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p124_s0025",
      "text": "yields the time duration in seconds.  The encoded exponent is defined as follows:",
      "bbox": [
        122.4,
        514.96,
        481.19,
        526.08
      ],
      "block_index": 10,
      "line_index": 4,
      "span_index": 1
    },
