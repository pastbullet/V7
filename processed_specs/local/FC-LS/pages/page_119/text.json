    {
      "span_id": "p119_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0002",
      "text": " 100",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0003",
      "text": " Table 102 – ELS Buffer Parameters Field",
      "bbox": [
        220.8,
        57.65,
        415.16,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0004",
      "text": "The Multi-frame ELS sequence supported bit indicates that the port either supports multi-frame ELS's",
      "bbox": [
        96.0,
        190.97,
        540.03,
        202.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0005",
      "text": "(bit 31=1) or does not support multi-frame ELS's (bit 31=0). ",
      "bbox": [
        96.0,
        202.96,
        359.54,
        214.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0006",
      "text": "The ELS Receive Data Field Size field (word 1, bits 11-0) specifies the largest ELS frame that may be",
      "bbox": [
        96.0,
        226.96,
        539.99,
        238.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0007",
      "text": "received by the FC_Port responding with the RPBC LS_ACC.  Values shall be a multiple of four",
      "bbox": [
        96.0,
        238.96,
        540.03,
        250.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0008",
      "text": "bytes, and less than 128 or greater than 2 112 are invalid.  For each class of service, the maximum",
      "bbox": [
        96.0,
        250.96,
        539.97,
        262.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p119_s0009",
      "text": "usable ELS Receive Data Field Size is the lessor of the reported ELS Receive Data Field Size or the",
      "bbox": [
        96.0,
        262.96,
        539.9,
        274.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p119_s0010",
      "text": "Buffer-to-buffer Receive Data Field Size reported during Login.",
      "bbox": [
        96.0,
        274.96,
        373.37,
        286.08
      ],
      "block_index": 5,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p119_s0011",
      "text": "4.2.37.4  Reply Sequence",
      "bbox": [
        96.0,
        298.96,
        214.87,
        310.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0012",
      "text": "LS_RJT: ",
      "bbox": [
        96.0,
        322.96,
        138.19,
        334.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0013",
      "text": "LS_RJT signifies rejection of the RPBC command",
      "bbox": [
        138.18,
        322.96,
        358.68,
        334.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p119_s0014",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        346.96,
        142.05,
        358.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0015",
      "text": "LS_ACC signifies acceptance of the RPBC Request and its Accept Payload.  The format",
      "bbox": [
        142.08,
        346.96,
        539.98,
        358.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p119_s0016",
      "text": "of the RPBC LS_ACC Payload is shown in table 103.",
      "bbox": [
        96.0,
        358.96,
        330.89,
        370.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0017",
      "text": "The ELS Buffer Parameter field contained in word 1 of the RPBC LA_ACC Payload relates to the",
      "bbox": [
        96.0,
        478.96,
        540.02,
        490.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0018",
      "text": "ELS buffer conditions of the sender of the RPBC_ACC ELS and the contents are shown in table 102.",
      "bbox": [
        96.0,
        490.96,
        540.05,
        502.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0019",
      "text": "4.2.38",
      "bbox": [
        96.0,
        514.96,
        123.74,
        526.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0020",
      "text": "Report node FC-4 Types (RNFT)",
      "bbox": [
        133.74,
        514.96,
        285.39,
        526.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0021",
      "text": "4.2.38.1  Description",
      "bbox": [
        96.0,
        538.96,
        192.64,
        550.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0022",
      "text": "The RNFT ELS provides for the exchange of supported FC-4 protocol lists.  It may be used any time",
      "bbox": [
        96.0,
        562.96,
        539.97,
        574.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0023",
      "text": "after N_Port Login to verify that the remote Nx_Port supports a given FC-4 protocol. ",
      "bbox": [
        96.0,
        574.96,
        468.65,
        586.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0024",
      "text": "The RNFT requests a list of the FC-4 protocols supported by the responder, and the RNFT LS_ACC",
      "bbox": [
        96.0,
        598.96,
        540.04,
        610.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0025",
      "text": "provides the requested list to the source of the of the RNFT.  ",
      "bbox": [
        96.0,
        610.96,
        366.51,
        622.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0026",
      "text": "A specific FC-4 may require that its Nx_Ports support RNFT, and therefore may conclude that a re-",
      "bbox": [
        96.0,
        635.02,
        539.95,
        646.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p119_s0027",
      "text": "mote Nx_Port that returns LS_RJT with reason code of \"Command not supported\" does not support",
      "bbox": [
        96.0,
        647.02,
        540.03,
        658.14
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p119_s0028",
      "text": "that FC-4.",
      "bbox": [
        96.0,
        659.02,
        140.37,
        670.14
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
