      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p102_s0008",
      "text": "The S_ID designates the Alias Server (FFFFF8h).  The D_ID field designates the Fab-",
      "bbox": [
        157.08,
        154.96,
        540.08,
        166.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p102_s0009",
      "text": "ric Controller (FFFFFDh).",
