        114.91,
        442.96,
        278.11,
        454.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p102_s0016",
      "text": " This is the Alias_ID that the Fabric shall recognize for the",
      "bbox": [
        277.98,
        442.96,
        539.96,
        454.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 3
    },
    {
