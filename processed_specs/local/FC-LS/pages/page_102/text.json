      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p102_s0023",
      "text": "Nx_Port List (NP_List):",
      "bbox": [
        122.4,
        514.96,
        235.79,
        526.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p102_s0024",
      "text": " The NP_List contains one entry for each Nx_Port for which the",
      "bbox": [
        235.74,
        514.96,
        540.06,
        526.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p102_s0025",
      "text": "Alias_ID is to be assigned as an Alias_ID.  The N_Port_ID shall be right aligned within the",
      "bbox": [
        122.4,
        526.96,
        539.95,
        538.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p102_s0026",
      "text": "NP_List entry (i.e., the high-order byte of the entry shall be ignored and the low-order 3 bytes",
      "bbox": [
        122.4,
        538.96,
        539.98,
        550.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p102_s0027",
      "text": "shall contain the N_Port_ID).",
      "bbox": [
        122.4,
        550.96,
        250.15,
        562.08
      ],
      "block_index": 11,
      "line_index": 5,
      "span_index": 1
    },
