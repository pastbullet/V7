      "text": " Nx_Port List Length (NP_List_Length): ",
      "bbox": [
        114.91,
        478.96,
        309.27,
        490.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p102_s0020",
      "text": "The NP_List_Length specifies the number of entries",
      "bbox": [
        309.42,
        478.96,
        540.08,
        490.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 3
