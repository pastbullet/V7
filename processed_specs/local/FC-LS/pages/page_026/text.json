        96.0,
        118.97,
        540.11,
        130.08
      ],
      "block_index": 4,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p026_s0012",
      "text": "is 0000b (Device_Data), 0010b (Extended Link Services), 0011b (FC-4 Link_Data), 0100b",
      "bbox": [
        96.0,
        130.97,
        539.96,
        142.08
      ],
      "block_index": 4,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p026_s0013",
      "text": "(Video_Data), or 1111b (Extended Routing) (see FC-FS-2).",
