{
  "doc_id": "FC-LS",
  "source_pdf": "/Users/zwy/毕设/V7/data/raw/FC-LS.pdf",
  "page": 190,
  "spans": [
    {
      "span_id": "p190_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0002",
      "text": " 171",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0003",
      "text": "Valid values for the Nx_Port End-to-end Credit field are 1 to 32767. The value 0 is reserved.",
      "bbox": [
        96.0,
        57.65,
        502.1,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0004",
      "text": "6.6.5.10  Open Sequences per Exchange",
      "bbox": [
        96.0,
        82.97,
        287.06,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0005",
      "text": "The value of open Sequences per Exchange field (word 3, bits 23 - 16) shall specify the maximum",
      "bbox": [
        96.0,
        106.97,
        539.99,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0006",
      "text": "number of Sequences that may be open at the Recipient at one time between a pair of Nx_Ports for",
      "bbox": [
        96.0,
        118.97,
        540.06,
        130.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0007",
      "text": "one Exchange.  The value of X+2 specifies the number of instances of Sequence Status that shall be",
      "bbox": [
        96.0,
        130.97,
        539.95,
        142.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0008",
      "text": "maintained by the Recipient for a single Exchange in the Exchange Status Block.  This value is used",
      "bbox": [
        96.0,
        142.96,
        539.95,
        154.08
      ],
      "block_index": 5,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p190_s0009",
      "text": "for Exchange and Sequence tracking.  The value of X limits the link facility resources required for er-",
      "bbox": [
        96.0,
        154.96,
        539.97,
        166.08
      ],
      "block_index": 5,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p190_s0010",
      "text": "ror detection and recovery.  The value of X is specified in bits 23-16 (see FC-FS-2).",
      "bbox": [
        96.0,
        166.96,
        463.65,
        178.08
      ],
      "block_index": 5,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p190_s0011",
      "text": "NOTE 19 – The number of SSBs specified at X+2 to be retained in the ESB ensures that if Sequence stream-",
      "bbox": [
        105.0,
        191.17,
        540.0,
        201.22
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0012",
      "text": "ing rules are followed, the ESB shall contain at least one \"good\" Sequence that ended normally.  Another SSB",
      "bbox": [
        105.0,
        202.15,
        540.03,
        212.2
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0013",
      "text": "position was allocated in order to allow for any race or timing conditions that might impact that \"good\" Se-",
      "bbox": [
        105.0,
        213.2,
        540.08,
        223.24
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0014",
      "text": "quence.",
      "bbox": [
        105.0,
        224.18,
        136.95,
        234.22
      ],
      "block_index": 6,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p190_s0015",
      "text": "The open Sequences per Exchange field is valid for PLOGI and PLOGI LS_ACC only.",
      "bbox": [
        96.0,
        250.97,
        475.95,
        262.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0016",
      "text": "6.6.5.11  CR_TOV",
      "bbox": [
        96.0,
        274.97,
        178.19,
        286.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0017",
      "text": "The CR_TOV value (word 3) shall be specified as a count of 1 ms increments (e.g., a value of",
      "bbox": [
        96.0,
        298.97,
        539.91,
        310.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0018",
      "text": "0000000Ah specifies a time period of 10 ms).  See FC-FS-2 for CR_TOV usage.  CR_TOV is appli-",
      "bbox": [
        96.0,
        310.97,
        540.02,
        322.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0019",
      "text": "cable to Class 1 and 6.  CR_TOV is not applicable to other Classes.  CR_TOV is only meaningful in",
      "bbox": [
        96.0,
        322.97,
        539.91,
        334.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0020",
      "text": "FLOGI LS_ACC.",
      "bbox": [
        96.0,
        334.96,
        170.43,
        346.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p190_s0021",
      "text": "6.6.6",
      "bbox": [
        96.0,
        358.96,
        118.22,
        370.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0022",
      "text": "Vendor Version Level",
      "bbox": [
        128.22,
        358.96,
        230.39,
        370.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0023",
      "text": "Vendor Version Level field (words 25-28) specifies vendor-specific information.  If the Valid Version",
      "bbox": [
        96.0,
        382.96,
        539.94,
        394.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0024",
      "text": "Level bit in the Common Service Parameters field (word 1, bit 29) is set to one, the Vendor Version",
      "bbox": [
        96.0,
        394.96,
        539.9,
        406.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0025",
      "text": "Level field contains valid information.  If the Valid Version Level bit  is set to zero, the Vendor Version",
      "bbox": [
        96.0,
        406.96,
        539.95,
        418.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0026",
      "text": "Level field is not meaningful.",
      "bbox": [
        96.0,
        418.96,
        222.05,
        430.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p190_s0027",
      "text": "6.6.7",
      "bbox": [
        96.0,
        442.96,
        118.22,
        454.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0028",
      "text": "Services Availability",
      "bbox": [
        128.22,
        442.96,
        224.89,
        454.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0029",
      "text": "6.6.7.1  Introduction",
      "bbox": [
        96.0,
        466.96,
        190.41,
        478.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0030",
      "text": "This field returns information regarding the Fabric’s ability to route to the defined well-known address-",
      "bbox": [
        96.0,
        490.96,
        539.96,
        502.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0031",
      "text": "es.  It is meaningful only for FLOGI LS_ACC.  Only bits 10 - 3 of word 30 are meaningful.  Word 29",
      "bbox": [
        96.0,
        502.96,
        539.96,
        514.08
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0032",
      "text": "and bits 31 - 11 and 2 - 0 of word 30 are reserved (see FC-FS-2).",
      "bbox": [
        96.0,
        514.96,
        384.88,
        526.08
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0033",
      "text": "6.6.7.2  Multicast Server",
      "bbox": [
        96.0,
        538.96,
        209.3,
        550.08
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0034",
      "text": "When set to one, the Multicast Server bit (word 30, bit 10) shall indicate that the Fabric supports rout-",
      "bbox": [
        96.0,
        562.96,
        540.0,
        574.08
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0035",
      "text": "ing to the well-known Multicast Server address identifier (i.e., FFFFF5h).  When set to zero, this bit",
      "bbox": [
        96.0,
        574.96,
        540.01,
        586.08
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0036",
      "text": "shall indicate that the Fabric does not support routing to the well-known Multicast Server address",
      "bbox": [
        96.0,
        586.96,
        540.02,
        598.08
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0037",
      "text": "identifier. See FC-FS-2 for the specification of this server.",
      "bbox": [
        96.0,
        598.96,
        349.84,
        610.08
      ],
      "block_index": 16,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p190_s0038",
      "text": "6.6.7.3  Clock Synchronization Server",
      "bbox": [
        96.0,
        622.96,
        273.76,
        634.08
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0039",
      "text": "When set to one, the Clock Synchronization Server bit (word 30, bit 9) shall indicate that the Fabric",
      "bbox": [
        96.0,
        647.02,
        539.94,
        658.14
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p190_s0040",
      "text": "supports routing to the well-known Clock Synchronization Server address identifier (FFFFF6h).",
      "bbox": [
        96.0,
        659.02,
        540.04,
        670.14
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p190_s0041",
      "text": "When set to zero, this bit shall indicate that the Fabric does not support routing to the well-known",
      "bbox": [
        96.0,
        671.02,
        539.95,
        682.14
      ],
      "block_index": 18,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p190_s0042",
      "text": "Clock Synchronization Server address identifier. See FC-FS-2 for the specification of this server.",
      "bbox": [
        96.0,
        683.02,
        522.06,
        694.14
      ],
      "block_index": 18,
      "line_index": 4,
      "span_index": 1
    }
  ],
  "asset_ids": []
}