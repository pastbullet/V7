        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p059_s0004",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        81.65,
        157.1,
        92.76
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p059_s0005",
      "text": "The D_ID field designates the destination of the request while the S_ID field designates",
      "bbox": [
        157.08,
        81.65,
        540.08,
        92.76
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p059_s0006",
      "text": "the source of the request.",
      "bbox": [
        96.0,
        93.65,
        209.35,
        104.76
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p059_s0007",
      "text": "Payload: ",
      "bbox": [
        96.0,
        117.64,
        140.41,
        128.76
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p059_s0008",
      "text": "The format of the Payload is shown in table 25.",
      "bbox": [
        140.4,
        117.64,
        348.7,
        128.76
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p059_s0009",
      "text": "The Payload size is limited by the smallest Data Field size supported by the destination Nx_Port and",
      "bbox": [
        96.0,
        274.96,
        540.07,
        286.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p059_s0010",
      "text": "the Fabric for the class being used.",
      "bbox": [
        96.0,
        286.96,
        251.58,
        298.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
