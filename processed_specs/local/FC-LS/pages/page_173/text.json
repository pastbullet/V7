  "spans": [
    {
      "span_id": "p173_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0002",
      "text": " 154",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0003",
      "text": "The Broadcast bit (word 1, bit 24) indicates whether broadcast is supported by the Fabric or not.  It is",
      "bbox": [
        96.0,
        57.65,
        540.0,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0004",
      "text": "only meaningful in the FLOGI LS_ACC.  For broadcast requirements see FC-FS-2.",
      "bbox": [
        96.0,
        69.65,
        461.44,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0005",
      "text": "6.6.2.4.13  Hunt Group",
      "bbox": [
        96.0,
        94.97,
        201.53,
        106.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0006",
      "text": "0 = Hunt Groups not supported.",
      "bbox": [
        96.0,
        118.97,
        236.27,
        130.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0007",
      "text": "1 = Hunt Groups supported.",
      "bbox": [
        96.0,
        130.97,
        219.58,
        142.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0008",
      "text": "The Hunt Group bit (word 1, bit 23) indicates whether or not the Fabric supports Hunt Group routing.",
      "bbox": [
        96.0,
        154.96,
        539.97,
        166.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0009",
      "text": "If it is set to zero, the Fabric shall not support Hunt Group routing.  If it is set to one, the Fabric shall",
      "bbox": [
        96.0,
        166.96,
        540.0,
        178.08
      ],
      "block_index": 6,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0010",
      "text": "support Hunt Group routing (see FC-FS-2).",
      "bbox": [
        96.0,
        178.96,
        286.54,
        190.08
      ],
      "block_index": 6,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p173_s0011",
      "text": "6.6.2.4.14    Query Buffer Conditions",
      "bbox": [
        96.0,
        202.96,
        267.62,
        214.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0012",
      "text": "0 = No buffer conditions to report.",
      "bbox": [
        96.0,
        226.96,
        244.5,
        238.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0013",
      "text": "1 = Buffer conditions to report.",
      "bbox": [
        96.0,
        238.96,
        230.17,
        250.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0014",
      "text": "The Query Buffer Conditions bit (word 1, bit 22) indicates whether or not the FC_Port has unusual",
      "bbox": [
        96.0,
        262.96,
        539.94,
        274.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0015",
      "text": "buffer conditions to report.  A Report Port Buffer Conditions (RPBC) ELS may be issued to gather the",
      "bbox": [
        96.0,
        274.96,
        539.92,
        286.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0016",
      "text": "buffer conditions.  An FC_Port shall only set the Query Buffer Conditions to 1 if the FC_Port supports",
      "bbox": [
        96.0,
        286.96,
        540.05,
        298.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p173_s0017",
      "text": "the RPBC ELS, and any of the following conditions are true:",
      "bbox": [
        96.0,
        298.96,
        360.46,
        310.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p173_s0018",
      "text": "a) The ELS Receive Data Field Size field is different that the Buffer-to-buffer Receive Data_Field",
      "bbox": [
        106.02,
        322.96,
        539.91,
        334.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0019",
      "text": "Size field in the common service parameters, or",
      "bbox": [
        122.4,
        334.96,
        333.43,
        346.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0020",
      "text": "b) multi-frame ELSs are not supported.",
      "bbox": [
        106.02,
        358.96,
        282.91,
        370.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0021",
      "text": "6.6.2.4.15  Clock Synchronization Primitive Capable",
      "bbox": [
        96.0,
        382.96,
        340.37,
        394.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0022",
      "text": "0 = not Clock Synchronization Primitive Capable",
      "bbox": [
        96.0,
        406.96,
        309.48,
        418.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0023",
      "text": "1 = Clock Synchronization Primitive Capable",
      "bbox": [
        96.0,
        418.96,
        292.85,
        430.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0024",
      "text": "The Clock Synchronization Primitive Capable bit (word 1, bit 20) indicates support for the Primitive",
      "bbox": [
        96.0,
        442.96,
        539.96,
        454.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0025",
      "text": "method of Clock Synchronization (see FC-FS-2).  If the bit is set to zero, the Primitive method of",
      "bbox": [
        96.0,
        454.96,
        539.87,
        466.08
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0026",
      "text": "Clock Synchronization is not supported.  If the bit is set to one, the meaning is as defined in table",
      "bbox": [
        96.0,
        466.96,
        539.75,
        478.08
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p173_s0027",
      "text": "154.",
      "bbox": [
        96.0,
        478.96,
        115.44,
        490.08
      ],
      "block_index": 14,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p173_s0028",
      "text": "6.6.2.4.16  R_T_TOV value",
      "bbox": [
        96.0,
        635.02,
        219.33,
        646.14
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0029",
      "text": "0 = Default value of 100 milliseconds.",
      "bbox": [
        96.0,
        659.02,
        261.73,
        670.13
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0030",
      "text": "1 = Short value of 100 microseconds.",
      "bbox": [
        96.0,
        671.02,
        261.26,
        682.13
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0031",
      "text": " Table 154 – Clock Synchronization Applicability",
      "bbox": [
        203.28,
        500.98,
        432.8,
        512.09
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0032",
      "text": "Type",
      "bbox": [
        167.88,
        523.0,
        191.17,
        534.11
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0033",
      "text": "Meaning if bit set to one",
      "bbox": [
        347.33,
        523.0,
        461.77,
        534.11
      ],
      "block_index": 18,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0034",
      "text": "Clock Synchronization Server (N_Port ",
      "bbox": [
        94.98,
        539.98,
        265.36,
        551.09
      ],
      "block_index": 19,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0035",
      "text": "Login only)",
      "bbox": [
        94.98,
        551.98,
        143.86,
        563.09
      ],
      "block_index": 19,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0036",
      "text": "The Clock Synchronization Server is capable of generating ",
      "bbox": [
        268.08,
        539.98,
        530.83,
        551.09
      ],
      "block_index": 19,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p173_s0037",
      "text": "clock synchronization Primitive Signals (see FC-FS-2).",
      "bbox": [
        268.08,
        551.98,
        509.12,
        563.09
      ],
      "block_index": 19,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p173_s0038",
      "text": "Other FC_Ports (N_Port Login only)",
      "bbox": [
        94.98,
        574.96,
        253.85,
        586.07
      ],
      "block_index": 20,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p173_s0039",
      "text": "The FC_Port is capable of receiving the clock synchronization ",
      "bbox": [
        268.08,
        568.96,
        542.28,
        580.07
      ],
      "block_index": 20,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p173_s0040",
      "text": "Primitive Signals (see FC-FS-2) and acting upon them.",
      "bbox": [
        268.08,
