        510.26,
        592.07
      ],
      "block_index": 20,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p173_s0041",
      "text": "Fabric (FLOGI LS_ACC only)",
      "bbox": [
        94.98,
        604.0,
        224.88,
