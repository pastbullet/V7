      "span_id": "p101_s0037",
      "text": "4.2.27.1  Description",
      "bbox": [
        96.0,
        635.02,
        192.63,
        646.14
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p101_s0038",
      "text": "The FACT ELS shall be sent to the Fabric Controller by the Alias Server (see FC-FS-2) to cause it to",
      "bbox": [
        96.0,
        659.02,
        540.02,
        670.14
