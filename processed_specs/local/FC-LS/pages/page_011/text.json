      "span_id": "p011_s0003",
      "text": "Introduction",
      "bbox": [
        96.0,
        57.12,
        165.97,
        70.51
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p011_s0004",
      "text": "FC-LS is one of the Fibre Channel family of standards. This family includes INCITS 373:2003, FC-",
      "bbox": [
        96.0,
        94.97,
        540.05,
        106.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p011_s0005",
      "text": "FS, which specifies the Framing and Signalling Interface. ANSI/INCITS 418:2006, FC-SW-4, is relat-",
      "bbox": [
        96.0,
        106.97,
        540.1,
        118.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p011_s0006",
      "text": "ed to Fabric requirements. INCITS 332:1999, FC-AL-2, specifies the arbitrated loop topology.",
      "bbox": [
        96.0,
        118.97,
        507.05,
        130.08
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p011_s0007",
      "text": "FC-LS defines requests and replies that comprise the set of Fibre Channel Extended Link Services",
      "bbox": [
        96.0,
        142.97,
        540.01,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
