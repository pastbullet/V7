      "span_index": 1
    },
    {
      "span_id": "p176_s0016",
      "text": "GI LS_ACC, of the Class Service Parameters to N_Port and Fabric Login.  The Class 1 and Class 6",
      "bbox": [
        96.0,
        250.96,
        539.91,
        262.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p176_s0017",
      "text": "Service Parameters are given in words 9 - 12.  The Class 2 Service Parameters are given in words",
      "bbox": [
        96.0,
        262.96,
        539.91,
        274.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p176_s0018",
      "text": "13 - 16.  The Class 3 Service Parameters are given in words 17 - 20. The words given in the second",
