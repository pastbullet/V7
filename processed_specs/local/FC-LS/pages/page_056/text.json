    {
      "span_id": "p056_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0002",
      "text": " 37",
      "bbox": [
        521.04,
        723.59,
        534.92,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0003",
      "text": "that originated the Exchange being aborted. Resources associated with the OX_ID in the Originator,",
      "bbox": [
        96.0,
        57.65,
        539.95,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0004",
      "text": "and with the RX_ID in the Responder, shall be released following transmission and reception of the",
      "bbox": [
        96.0,
        69.65,
        539.95,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p056_s0005",
      "text": "LS_ACC reply Sequence if the Exchange had been aborted with ABTS-LS.",
      "bbox": [
        96.0,
        81.65,
        427.65,
        92.76
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p056_s0006",
      "text": "Both the Originator and Responder shall ensure that the OX_ID and RX_ID pair being terminated is",
      "bbox": [
        96.0,
        106.97,
        540.01,
        118.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0007",
      "text": "currently associated with the OX_ID and RX_ID pair specified in the RRQ Request.",
      "bbox": [
        96.0,
        118.97,
        463.2,
        130.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p056_s0008",
      "text": "The Recovery_Qualifier range shall be timed out for an R_A_TOV timeout period (i.e., RRQ shall not",
      "bbox": [
        96.0,
        142.96,
        539.98,
        154.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0009",
      "text": "be transmitted until an R_A_TOV timeout period after BA_ACC for ABTS has been received) by the",
      "bbox": [
        96.0,
        154.96,
        540.04,
        166.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p056_s0010",
      "text": "Nx_Port that transmitted and successfully completed the ABTS frame.",
      "bbox": [
        96.0,
        166.96,
        405.48,
        178.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p056_s0011",
      "text": "4.2.12.2  Protocol",
      "bbox": [
        96.0,
        190.96,
        178.22,
        202.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0012",
      "text": "a) Reinstate Recovery Qualifier Request Sequence",
      "bbox": [
        106.02,
        214.96,
        337.34,
        226.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0013",
      "text": "b) LS_ACC or LS_RJT Reply Sequence",
      "bbox": [
        106.02,
        238.96,
        287.89,
        250.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0014",
      "text": "4.2.12.3  Request Sequence",
      "bbox": [
        96.0,
        262.96,
        227.06,
        274.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0015",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        286.96,
        157.1,
        298.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0016",
      "text": "The D_ID field designates the destination Nx_Port of the RRQ Request Sequence",
      "bbox": [
        157.08,
        286.96,
        539.88,
        298.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p056_s0017",
      "text": "while the S_ID field designates the source Nx_Port that is requesting that the Recovery_Qualifier be",
      "bbox": [
        96.0,
        298.96,
        540.03,
        310.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p056_s0018",
      "text": "reinstated.",
      "bbox": [
        96.0,
        310.96,
        142.65,
        322.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p056_s0019",
      "text": "Exchange: ",
      "bbox": [
        96.0,
        334.96,
        149.26,
        346.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p056_s0020",
      "text": "A separate Exchange is required.",
      "bbox": [
        149.34,
        334.96,
        297.08,
        346.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 2
    },
    {
