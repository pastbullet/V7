    {
      "span_id": "p139_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0002",
      "text": " 120",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0003",
      "text": "If the Domain Controller that receives an FFI_RTM request currently is not the AE Principal Switch, it",
      "bbox": [
        96.0,
        57.65,
        539.96,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0004",
      "text": "shall respond with an LS_RJT reply with a reason code of “Logical error”.",
      "bbox": [
        96.0,
        69.65,
        418.64,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0005",
      "text": "If a destination receives this ELS Request that is not a Domain Controller, it shall respond with an",
      "bbox": [
        96.0,
        94.97,
        539.82,
        106.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0006",
      "text": "LS_RJT reply with a reason code of “Command not supported.”",
      "bbox": [
        96.0,
        106.97,
        376.49,
        118.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0007",
      "text": "4.2.46.2  Protocol",
      "bbox": [
        96.0,
        130.97,
        178.28,
        142.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0008",
      "text": "a) FFI Domain Topology Map Request Sequence; and",
      "bbox": [
        106.02,
        154.96,
        350.68,
        166.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0009",
      "text": "b) LS_ACC or LS_RJT Reply Sequence.",
      "bbox": [
        106.02,
        178.96,
        290.73,
        190.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0010",
      "text": "4.2.46.3  Request Sequence",
      "bbox": [
        96.0,
        202.96,
        227.13,
        214.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0011",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        226.96,
        157.1,
        238.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0012",
      "text": "The S_ID field value identifies the Nx_Port requesting the Domain Topology Map from",
      "bbox": [
        157.32,
        226.96,
        539.92,
        238.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p139_s0013",
      "text": "the Domain Controller of the AE Principal Switch. The D_ID designates the Domain Controller of the",
      "bbox": [
        96.0,
        238.96,
        539.98,
        250.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0014",
      "text": "AE Principal Switch in the form FFFCxxh, where xx is the one-byte value assigned to the Domain",
      "bbox": [
        96.0,
        250.96,
        539.86,
        262.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p139_s0015",
      "text": "Controller.",
      "bbox": [
        96.0,
        262.96,
        142.1,
        274.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p139_s0016",
      "text": "Payload: ",
      "bbox": [
        96.0,
        286.96,
        140.41,
        298.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0017",
      "text": "The format of the FFI_RTM Request Payload is shown in table 134.",
      "bbox": [
        140.4,
        286.96,
        439.2,
        298.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p139_s0018",
      "text": "4.2.46.4  Reply Sequence",
      "bbox": [
        96.0,
        394.96,
        214.96,
        406.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0019",
      "text": "LS_RJT: ",
      "bbox": [
        96.0,
        418.96,
        139.27,
        430.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0020",
      "text": "LS_RJT signifies the rejection of the FFI_RTM Request. The LS_RJT reply contains an ap-",
      "bbox": [
        139.2,
        418.96,
        540.02,
        430.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p139_s0021",
      "text": "propriate reject reason code.",
      "bbox": [
        96.0,
        430.96,
        223.19,
        442.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0022",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        454.96,
        143.82,
        466.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0023",
      "text": "LS_ACC signifies acceptance of a valid FFI_RTM Request and that the AE Principal",
      "bbox": [
        144.42,
        454.96,
        540.0,
        466.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p139_s0024",
      "text": "Switch has transmitted the requested data. The format of the LS_ACC Payload for FFI_RTM is",
      "bbox": [
        96.0,
        466.96,
        540.02,
        478.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0025",
      "text": "shown in table 135. ",
      "bbox": [
        96.0,
        478.96,
        184.86,
        490.08
      ],
      "block_index": 13,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p139_s0026",
      "text": "Payload Length: ",
      "bbox": [
        96.0,
        671.02,
        176.42,
        682.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p139_s0027",
      "text": "This field is the length in bytes of the entire Payload, inclusive of the length of word",
      "bbox": [
        176.28,
        671.02,
        540.01,
        682.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p139_s0028",
      "text": "0. This value shall be a multiple of 4 bytes. The minimum value of this field is 28 bytes. The maximum",
      "bbox": [
        96.0,
        683.02,
        540.03,
        694.14
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p139_s0029",
      "text": "value of this field is 65532.",
      "bbox": [
        96.0,
        695.02,
        213.75,
        706.14
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
