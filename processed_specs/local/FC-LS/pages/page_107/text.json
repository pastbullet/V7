    {
      "span_id": "p107_s0028",
      "text": "4.2.32.1  Description",
      "bbox": [
        96.0,
        550.96,
        192.63,
        562.07
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p107_s0029",
      "text": "The FDISC ELS shall transfer Service Parameters from the initiating Nx_Port to the Fx_Port at well-",
      "bbox": [
        96.0,
        574.96,
        540.0,
        586.07
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p107_s0030",
      "text": "known F_Port_ID (i.e., FFFFFEh).  This provides the means for the exchange of Service Parameters",
      "bbox": [
        96.0,
        586.96,
        539.96,
        598.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p107_s0031",
      "text": "and the assignment of an additional N_Port_IDs without changing service parameters.",
      "bbox": [
        96.0,
        598.96,
        476.56,
        610.07
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
