    },
    {
      "span_id": "p107_s0004",
      "text": "The format of the Payload for the LS_ACC indicating that this request has been success-",
      "bbox": [
        142.08,
        57.65,
        539.99,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p107_s0005",
      "text": "fully completed is shown in table 88.  If the Nx_Port is unable to perform all of the above functions, it",
      "bbox": [
        96.0,
        69.65,
        540.02,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
