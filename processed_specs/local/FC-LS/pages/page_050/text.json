    },
    {
      "span_id": "p050_s0004",
      "text": "a) Logout Request Sequence",
      "bbox": [
        106.02,
        82.97,
        240.73,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0005",
      "text": "b) LS_ACC or LS_RJT Reply Sequence",
      "bbox": [
        106.02,
        106.97,
        287.89,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0006",
      "text": "4.2.8.3  Request Sequence",
      "bbox": [
        96.0,
        130.97,
        221.54,
        142.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0007",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        154.96,
        157.1,
        166.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0008",
      "text": "For an explicit Nx_Port Logout, the S_ID field designates the source Nx_Port_ID re-",
      "bbox": [
        157.08,
        154.96,
        540.19,
        166.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p050_s0009",
      "text": "questing Logout and the D_ID field designates the destination Nx_Port of the Logout Request. For an",
      "bbox": [
        96.0,
        166.96,
        539.94,
        178.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p050_s0010",
      "text": "explicit Fabric Logout originated by an Nx_Port, the S_ID field shall be the Nx_Port_ID to be logged",
      "bbox": [
        96.0,
        178.96,
        540.04,
        190.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p050_s0011",
      "text": "out (i.e., the same as the N_Port_ID in the Payload) and the D_ID shall be the F_Port Well-known ad-",
      "bbox": [
        96.0,
        190.96,
        540.02,
        202.08
      ],
      "block_index": 7,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p050_s0012",
      "text": "dress (i.e., FFFFFEh). For an explicit Fabric Logout originated by the Fabric, the S_ID field shall be",
      "bbox": [
        96.0,
        202.96,
        539.95,
        214.08
      ],
      "block_index": 7,
      "line_index": 5,
      "span_index": 1
    },
    {
      "span_id": "p050_s0013",
      "text": "the F_Port Well-known address (i.e., FFFFFEh) and the D_ID shall be the Nx_Port_ID to be logged",
      "bbox": [
        96.0,
        214.96,
        539.95,
        226.08
      ],
      "block_index": 7,
      "line_index": 6,
      "span_index": 1
    },
    {
      "span_id": "p050_s0014",
      "text": "out (i.e., the same as the N_Port_ID in the Payload).",
      "bbox": [
        96.0,
        226.96,
        327.69,
        238.08
      ],
      "block_index": 7,
      "line_index": 7,
      "span_index": 1
    },
    {
