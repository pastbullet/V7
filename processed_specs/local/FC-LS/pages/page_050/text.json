    {
      "span_id": "p050_s0027",
      "text": "4.2.9.1  Description",
      "bbox": [
        96.0,
        622.96,
        187.05,
        634.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0028",
      "text": "The RCS ELS requests the Fabric Controller to return the current dedicated connection status for the",
      "bbox": [
        96.0,
        647.02,
        539.94,
        658.14
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0029",
      "text": "Nx_Port specified in the Payload of the RCS frame.  The RCS Request provides the means by which",
      "bbox": [
        96.0,
        659.02,
        540.01,
        670.14
      ],
      "block_index": 14,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p050_s0030",
      "text": "an Nx_Port may interrogate the Fabric for the Connection status of other Nx_Ports within the Fabric.",
      "bbox": [
        96.0,
        671.02,
        538.11,
        682.14
      ],
      "block_index": 14,
      "line_index": 3,
      "span_index": 1
    },
