      "text": "Payload: ",
      "bbox": [
        96.0,
        250.96,
        140.41,
        262.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0016",
      "text": "The format of the Payload is shown in table 12. ",
      "bbox": [
        140.4,
        250.96,
        351.52,
        262.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p050_s0017",
      "text": "4.2.8.4  Reply Sequence",
      "bbox": [
        96.0,
        406.96,
        209.29,
        418.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0018",
      "text": "LS_RJT: ",
      "bbox": [
        96.0,
        430.96,
        138.19,
        442.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0019",
      "text": "LS_RJT signifies rejection of the LOGO command.",
      "bbox": [
        138.18,
        430.96,
        362.59,
        442.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p050_s0020",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        454.96,
        142.05,
        466.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0021",
      "text": "LS_ACC signifies that service has been removed for the N_Port_ID indicated in the pay-",
      "bbox": [
        142.08,
        454.96,
        540.0,
        466.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p050_s0022",
      "text": "load of the LOGO ELS. When the LOGO ELS requested Fabric Logout, LS_ACC signifies that the",
      "bbox": [
        96.0,
        466.96,
        539.96,
        478.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p050_s0023",
      "text": "N_Port_ID specified in the Payload of the LOGO ELS has been logged out from the Fabric and re-",
      "bbox": [
        96.0,
        478.96,
        540.06,
        490.08
      ],
      "block_index": 11,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p050_s0024",
      "text": "leased. The format of the LS_ACC Payload is shown in table 13.",
      "bbox": [
        96.0,
        490.96,
        380.93,
        502.08
      ],
      "block_index": 11,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p050_s0025",
      "text": "4.2.9",
      "bbox": [
        96.0,
        598.96,
        118.24,
        610.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p050_s0026",
      "text": "Read Connection Status (RCS)",
      "bbox": [
        128.24,
        598.96,
        274.18,
        610.08
      ],
      "block_index": 12,
      "line_index": 2,
