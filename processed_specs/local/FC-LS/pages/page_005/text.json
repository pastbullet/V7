      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p005_s0043",
      "text": "neither the developers nor the publisher have undertaken a patent search in order to identify which,",
      "bbox": [
        78.0,
        442.67,
