      "text": "Institute require that action be taken periodically to reaffirm, revise, or withdraw this",
      "bbox": [
        156.3,
        346.24,
        516.26,
        357.36
      ],
      "block_index": 4,
      "line_index": 3,
      "span_index": 1
    },
    {
