      "text": "CAUTION NOTICE:",
      "bbox": [
        156.3,
        321.28,
        250.02,
        332.4
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p005_s0021",
      "text": " This American National Standard may be revised or",
      "bbox": [
        250.02,
        321.28,
        516.41,
        332.4
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p005_s0022",
      "text": "withdrawn at any time. The procedures of the American National Standards",
      "bbox": [
        156.3,
        333.76,
        516.38,
        344.88
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
