    },
    {
      "span_id": "p125_s0018",
      "text": "LS_ACC: ",
      "bbox": [
        96.0,
        202.97,
        142.05,
        214.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p125_s0019",
      "text": "LS_ACC signifies acceptance of the SBRP Request and presents SBRP data.  The format",
      "bbox": [
        142.08,
        202.97,
        539.92,
        214.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p125_s0020",
      "text": "of the LS_ACC Payload is shown in table 111.",
      "bbox": [
        96.0,
        214.96,
        300.41,
        226.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p125_s0021",
      "text": "The LS_ACC Payload conveys either:",
      "bbox": [
        96.0,
        238.96,
        263.82,
        250.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p125_s0022",
      "text": "a) the current Bit Error Rate Reporting Parameters (i.e., the requestor is querying for currently set",
      "bbox": [
        106.02,
        262.96,
        539.91,
        274.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p125_s0023",
      "text": "parameters) or,",
      "bbox": [
        122.4,
        274.96,
        190.68,
        286.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p125_s0024",
      "text": "b) the accepted Bit Error Rate Reporting Parameters (a request to set the parameters was ac-",
      "bbox": [
        106.02,
        298.96,
        539.98,
        310.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p125_s0025",
      "text": "cepted) or,",
      "bbox": [
        122.4,
        310.96,
        170.16,
        322.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p125_s0026",
      "text": "c)",
      "bbox": [
        106.02,
        334.96,
        114.34,
        346.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p125_s0027",
      "text": "acceptable Bit Error Rate Report Parameters (a request to set the parameters was rejected be-",
      "bbox": [
        122.36,
        334.96,
        539.99,
        346.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
