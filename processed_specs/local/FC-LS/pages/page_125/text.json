      "block_index": 12,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p125_s0031",
      "text": " When a request to set the reporting parameters is indicated  (re-",
      "bbox": [
        244.86,
        550.96,
        540.12,
        562.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 3
    },
    {
