      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p206_s0051",
      "text": "Exchange Virtual Fabrics Parameters Processing",
      "bbox": [
        119.88,
        550.96,
        353.19,
        562.08
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p206_s0052",
