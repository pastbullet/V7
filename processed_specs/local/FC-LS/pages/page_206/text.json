      "bbox": [
        119.88,
        406.96,
        243.2,
        418.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p206_s0043",
      "text": "A VF capable N_Port shall maintain the following configuration parameters:",
      "bbox": [
        96.0,
        430.96,
        428.15,
        442.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p206_s0044",
      "text": "a) Tagging Administrative Status, used to negotiate the VFT tagging operational mode of the",
      "bbox": [
        106.02,
        454.96,
        539.97,
        466.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p206_s0045",
      "text": "N_Port (see 4.2.43.2.2);",
      "bbox": [
        122.4,
        466.96,
        229.02,
        478.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p206_s0046",
      "text": "b) Port VF_ID (see 4.2.43.2.3); and",
      "bbox": [
        106.02,
        490.96,
        266.87,
        502.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p206_s0047",
      "text": "c)",
      "bbox": [
        106.02,
        514.96,
        114.35,
        526.08
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p206_s0048",
      "text": "Locally-Enabled VF_ID List, used to negotiate the list of Virtual Fabrics operational over the",
      "bbox": [
        122.37,
        514.96,
        540.0,
        526.08
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p206_s0049",
      "text": "N_Port (see 4.2.43.2.4).",
      "bbox": [
        122.4,
        526.96,
        229.02,
        538.08
      ],
      "block_index": 15,
      "line_index": 3,
      "span_index": 1
    },
    {
