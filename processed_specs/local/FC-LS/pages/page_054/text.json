      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p054_s0020",
      "text": "The S_ID field designates the source Nx_Port requesting the timeout interval values.",
      "bbox": [
        157.08,
        442.96,
        540.07,
        454.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 2
    },
    {
