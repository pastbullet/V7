      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p054_s0004",
      "text": "LS_ACC signifies that the FC_Port has transmitted the requested data.  The format of the",
      "bbox": [
        142.08,
        57.65,
        540.03,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p054_s0005",
      "text": "LS_ACC Payload is shown in table 18.  The format of the Link Error Status Block is specified in FC-",
      "bbox": [
        96.0,
        69.65,
        539.96,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
