      "text": "The D_ID field designates the destination FC_Port",
      "bbox": [
        96.0,
        454.96,
        318.73,
        466.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p054_s0022",
