      "text": "4.2.25.5  Request Sequence",
      "bbox": [
        96.0,
        334.96,
        227.06,
        346.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p098_s0019",
      "text": "Addressing: ",
      "bbox": [
        96.0,
        358.96,
        157.1,
        370.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p098_s0020",
      "text": "The S_ID designates the source port requesting registration for Link Incident Records.",
      "bbox": [
        157.08,
        358.96,
        539.98,
        370.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p098_s0021",
      "text": "The D_ID field designates the port receiving the registration request.",
      "bbox": [
        96.0,
        370.96,
        398.13,
        382.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
