    {
      "span_id": "p044_s0004",
      "text": "LS_ACC signifies successful completion of the ADVC function and permanently replaces",
      "bbox": [
        142.08,
        57.65,
        539.98,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p044_s0005",
      "text": "the end-to-end Credit in effect for the current N_Port Login.",
