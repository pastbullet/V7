  "spans": [
    {
      "span_id": "p188_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0002",
      "text": " 169",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0003",
      "text": "6.6.5.6.4  Error policy supported",
      "bbox": [
        96.0,
        57.65,
        248.17,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0004",
      "text": "The definition of the Error policy supported bits (word 1, bits 28-27) is shown in table 169.",
      "bbox": [
        96.0,
        82.97,
        490.34,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0005",
      "text": "These bits are set to specify the types of support possible for missing frame conditions processed by",
      "bbox": [
        96.0,
        250.97,
        539.93,
        262.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0006",
      "text": "the destination Nx_Port.  The policy used for a given Exchange shall be specified as discard or pro-",
      "bbox": [
        96.0,
        262.97,
        539.98,
        274.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p188_s0007",
      "text": "cess by the Exchange Originator (see FC-FS-2).",
      "bbox": [
        96.0,
        274.97,
        309.89,
        286.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p188_s0008",
      "text": "6.6.5.6.5  Categories per Sequence",
      "bbox": [
        96.0,
        298.97,
        260.4,
        310.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0009",
      "text": "The definition of the Categories per Sequence bits (word 1, bits 25-24) is shown in table 170.",
      "bbox": [
        96.0,
        322.97,
        505.97,
        334.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0010",
      "text": "The setting of these bits shall specify that the Recipient is capable of processing one, two, or more",
      "bbox": [
        96.0,
        490.97,
        539.88,
        502.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0011",
      "text": "than two Information Categories (R_CTL bits 27-24 in the Frame_Header) in a single Sequence.  Bits",
      "bbox": [
        96.0,
        502.97,
        540.0,
        514.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p188_s0012",
      "text": "25-24 are applicable to each Class of Service since support for an individual Class may offer different",
      "bbox": [
        96.0,
        514.96,
        540.08,
        526.08
      ],
      "block_index": 8,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p188_s0013",
      "text": "capabilities in the same Nx_Port.",
      "bbox": [
        96.0,
        526.96,
        241.45,
        538.08
      ],
      "block_index": 8,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p188_s0014",
      "text": "When an Nx_Port is acting as a Sequence Initiator, it shall restrict the number of Information Catego-",
      "bbox": [
        96.0,
        550.96,
        540.07,
        562.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0015",
      "text": "ries per Sequence based on the Sequence Recipient's capability as specified during N_Port Login.",
      "bbox": [
        96.0,
        562.96,
        540.0,
        574.08
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p188_s0016",
      "text": "An Nx_Port's capability for processing Information Categories in a single Sequence may prohibit that",
      "bbox": [
        96.0,
        574.96,
        540.02,
        586.08
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p188_s0017",
      "text": "Nx_Port from communicating in certain FC-4 protocols.",
      "bbox": [
        96.0,
        586.96,
        339.3,
        598.08
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p188_s0018",
      "text": "Each FC-4 should allow the ability to communicate using only one Information Category per Se-",
      "bbox": [
        96.0,
        610.96,
        540.13,
        622.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0019",
      "text": "quence but always provide the ability to communicate using multiple Information Categories per Se-",
      "bbox": [
        96.0,
        622.96,
        540.01,
        634.08
      ],
      "block_index": 10,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p188_s0020",
      "text": "quence where possible, and when performance may be enhanced.",
      "bbox": [
        96.0,
        634.96,
        391.01,
        646.08
      ],
      "block_index": 10,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p188_s0021",
      "text": "6.6.5.6.6  Clock synchronization ELS capable",
      "bbox": [
        96.0,
        659.02,
        309.26,
        670.14
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0022",
      "text": "0 = Recipient does not have clock synchronization ELS capability",
      "bbox": [
        96.0,
        683.02,
        383.96,
        694.14
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p188_s0023",
      "text": "1 = Recipient has clock synchronization ELS capability",
      "bbox": [
        96.0,
        695.02,
        337.29,
        706.14
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
