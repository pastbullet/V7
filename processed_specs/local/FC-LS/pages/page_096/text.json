    {
      "span_id": "p096_s0024",
      "text": "Implicit incident: ",
      "bbox": [
        153.3,
        147.64,
        227.18,
        158.76
      ],
      "block_index": 9,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p096_s0025",
      "text": "A condition, caused by an event known to have occurred within the incident port, has ",
      "bbox": [
        153.3,
        159.64,
        530.48,
        170.76
      ],
      "block_index": 9,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p096_s0026",
      "text": "been recognized by the incident port.  The condition affects the attached link in such a ",
      "bbox": [
        153.3,
        171.64,
        533.66,
        182.76
      ],
      "block_index": 9,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p096_s0027",
      "text": "way that it may cause a link incident to be recognized by the connected port.",
