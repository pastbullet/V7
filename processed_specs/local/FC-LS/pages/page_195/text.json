  "page": 195,
  "spans": [
    {
      "span_id": "p195_s0001",
      "text": "INCITS xxx-200x Link Services Rev 1.61 November 3, 2006",
      "bbox": [
        301.08,
        37.27,
        539.95,
        47.32
      ],
      "block_index": 1,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0002",
      "text": " 176",
      "bbox": [
        518.28,
        723.59,
        537.71,
        734.7
      ],
      "block_index": 2,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0003",
      "text": "When sent to the Clock Synchronization Server (i.e., FFFFF6h) during PLOGI, these bits indicate the",
      "bbox": [
        96.0,
        57.65,
        540.02,
        68.76
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0004",
      "text": "requested least significant bit position within the 64-bit Clock Count field in the CSU ELS Payload.",
      "bbox": [
        96.0,
        69.65,
        527.65,
        80.76
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0005",
      "text": "When received from the Clock Synchronization Server (i.e., FFFFF6h), this field represents the least",
      "bbox": [
        96.0,
        94.97,
        540.03,
        106.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0006",
      "text": "significant bit position within the 64-bit Clock Count field that contains meaningful information.",
      "bbox": [
        96.0,
        106.97,
        508.12,
        118.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0007",
      "text": "(e.g., a value of 001000b indicates that the LSB of byte 6 of the Clock Count field is the lowest bit that",
      "bbox": [
        96.0,
        130.97,
        540.11,
        142.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0008",
      "text": "contains meaningful information).",
      "bbox": [
        96.0,
        142.96,
        243.16,
        154.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0009",
      "text": "6.6.9.1.6  Clock Synchronization Update Period",
      "bbox": [
        96.0,
        166.96,
        318.76,
        178.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0010",
      "text": "When sent to the Clock Synchronization Server (i.e., FFFFF6h), the Clock Synchronization Update",
      "bbox": [
        96.0,
        190.96,
        539.91,
        202.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0011",
      "text": "Period field (word 63) indicates the requested time, in microseconds, between consecutive updates",
      "bbox": [
        96.0,
        202.96,
        539.98,
        214.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0012",
      "text": "from the Clock Synchronization server.",
      "bbox": [
        96.0,
        214.96,
        267.58,
        226.08
      ],
      "block_index": 7,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p195_s0013",
      "text": "When received from the Clock Synchronization Server (i.e., FFFFF6h), it represents the time, in mi-",
      "bbox": [
        96.0,
        238.96,
        540.04,
        250.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0014",
      "text": "croseconds, between consecutive updates from the Clock Synchronization server.",
      "bbox": [
        96.0,
        250.96,
        458.78,
        262.08
      ],
      "block_index": 8,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0015",
      "text": "This field is not meaningful for FLOGI and shall be set to zero.",
      "bbox": [
        96.0,
        274.96,
        370.52,
        286.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0016",
      "text": "6.6.9.2  Fabric Login",
      "bbox": [
        96.0,
        298.96,
        192.1,
        310.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0017",
      "text": "6.6.9.2.1  Applicability",
      "bbox": [
        96.0,
        322.96,
        199.87,
        334.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0018",
      "text": "The Clock Synchronization Quality of Service field contains meaningful information only if either",
      "bbox": [
        96.0,
        346.96,
        540.03,
        358.08
      ],
      "block_index": 12,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0019",
      "text": "Word 1, bit 20 - Clock Synchronization Primitive Capable of the Common features field is set to one,",
      "bbox": [
        96.0,
        358.96,
        539.96,
        370.08
      ],
      "block_index": 12,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0020",
      "text": "or Word 1, bit 19 - Clock Synchronization ELS capable of the Recipient control field is set to one.  If",
      "bbox": [
        96.0,
        370.96,
        540.06,
        382.08
      ],
      "block_index": 12,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p195_s0021",
      "text": "this field does not contain meaningful information, it shall be set to zero (see FC-FS-2).",
      "bbox": [
        96.0,
        382.96,
        479.21,
        394.08
      ],
      "block_index": 12,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p195_s0022",
      "text": "The Fx_Port Clock Synchronization Quality of Service field is illustrated in table 176.",
      "bbox": [
        96.0,
        406.96,
        467.57,
        418.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0023",
      "text": "6.6.9.2.2  CS_Transfer_Accuracy",
      "bbox": [
        96.0,
        538.96,
        250.36,
        550.08
      ],
      "block_index": 14,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0024",
      "text": "The CS_Transfer_Accuracy field contains CS_Transfer_Accuracy_Mantissa  (word 62, bits 23-21)",
      "bbox": [
        96.0,
        562.96,
        539.92,
        574.08
      ],
      "block_index": 15,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0025",
      "text": "and CS_Transfer_Accuracy_Exponent (word 62, bits 20-16).",
      "bbox": [
        96.0,
        574.96,
        363.77,
        586.08
      ],
      "block_index": 15,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0026",
      "text": "These bits indicate the accuracy that the Fabric maintains in passing along to the clients the clock",
      "bbox": [
        96.0,
        598.96,
        539.93,
        610.08
      ],
      "block_index": 16,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0027",
      "text": "synchronization value it receives from the Clock Synchronization Server.    Specifically, the Fabric",
      "bbox": [
        96.0,
        610.96,
        539.94,
        622.07
      ],
      "block_index": 16,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p195_s0028",
      "text": "shall supply a CS_Transfer_Accuracy value such that the Clock Synchronization value supplied to",
      "bbox": [
        96.0,
        622.96,
        539.84,
        634.07
      ],
      "block_index": 16,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p195_s0029",
      "text": "the clients is always within the range of:",
      "bbox": [
        96.0,
        634.96,
        271.59,
        646.07
      ],
      "block_index": 16,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p195_s0030",
      "text": "(T_server + T_fabric_delay) ",
      "bbox": [
        96.0,
        659.02,
        221.77,
        670.13
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p195_s0031",
      "text": "±",
      "bbox": [
        221.82,
        658.02,
        227.28,
        670.21
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p195_s0032",
      "text": " (0.5 + CS_Accuracy_Mantissa  * 2",
      "bbox": [
        227.28,
        659.02,
        382.55,
        670.13
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p195_s0033",
      "text": "-4",
      "bbox": [
        382.56,
        656.8,
        389.64,
        665.7
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 4
    },
    {
      "span_id": "p195_s0034",
      "text": ")* 2",
      "bbox": [
        389.64,
        659.03,
        405.2,
        670.14
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 5
    },
    {
      "span_id": "p195_s0035",
