      "bbox": [
        405.18,
        654.55,
        529.52,
        665.27
      ],
      "block_index": 17,
      "line_index": 1,
      "span_index": 6
    },
    {
      "span_id": "p195_s0036",
      "text": "where:",
      "bbox": [
        120.0,
        683.03,
        149.94,
        694.14
      ],
      "block_index": 18,
      "line_index": 1,
      "span_index": 1
    },
