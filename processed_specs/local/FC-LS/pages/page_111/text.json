    {
      "span_id": "p111_s0005",
      "text": "4.2.34.1  Description",
      "bbox": [
        96.0,
        430.97,
        192.63,
        442.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p111_s0006",
      "text": "The TPRLO ELS is used to invalidate the operating environments (i.e., remove image pairs and as-",
      "bbox": [
        96.0,
        454.96,
        540.01,
        466.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p111_s0007",
      "text": "sociated resources) at the recipient Nx_Port for the specified TYPE.",
      "bbox": [
        96.0,
        466.96,
        395.42,
        478.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p111_s0008",
      "text": "TPRLO has the same effect on the recipient Nx_Port as if all Nx_Ports that have performed Process",
      "bbox": [
        96.0,
        490.96,
        540.06,
        502.08
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p111_s0009",
      "text": "Login with the recipient Nx_Port for the specified TYPE, performed PRLO with the recipient Nx_Port.",
      "bbox": [
        96.0,
        502.96,
