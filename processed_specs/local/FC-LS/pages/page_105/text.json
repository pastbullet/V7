    {
      "span_id": "p105_s0028",
      "text": "LS_RJT signifies the rejection of the NACT Request.  An LS_RJT shall be returned if the",
      "bbox": [
        138.18,
        586.96,
        540.0,
        598.08
      ],
      "block_index": 13,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p105_s0029",
      "text": "Alias_ID is unable to be activated as an Alias_ID.  A reason code of \"Unable to perform command re-",
      "bbox": [
        96.0,
        598.96,
        540.04,
        610.08
      ],
      "block_index": 13,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p105_s0030",
