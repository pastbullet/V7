        286.08
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0004",
      "text": " Alias Group Token (Alias_Token):",
      "bbox": [
        114.91,
        274.97,
        284.71,
        286.08
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p105_s0005",
      "text": " This is the token identifying the Alias Group.",
      "bbox": [
        284.64,
        274.97,
        487.14,
        286.08
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p105_s0006",
      "text": " It contains",
      "bbox": [
        490.5,
        274.97,
        540.0,
        286.08
      ],
      "block_index": 3,
      "line_index": 1,
      "span_index": 5
    },
    {
      "span_id": "p105_s0007",
      "text": "the Alias_Class and Alias_Qualifier of the Alias Group the Nx_Port is being requested to join.",
      "bbox": [
        122.4,
        286.97,
        539.94,
        298.08
      ],
      "block_index": 3,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p105_s0008",
      "text": "The Nx_Port validates that it supports that particular Alias Class.  See FC-GS-5 for a descrip-",
      "bbox": [
        122.4,
        298.97,
        540.05,
        310.08
      ],
      "block_index": 3,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p105_s0009",
      "text": "tion of the Alias_Token.",
      "bbox": [
        122.4,
        310.97,
        226.78,
        322.08
      ],
      "block_index": 3,
      "line_index": 4,
      "span_index": 1
    },
    {
      "span_id": "p105_s0010",
      "text": "b)",
      "bbox": [
        106.02,
        334.96,
        114.92,
        346.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0011",
      "text": " Alias Group Identifier (Alias_ID):",
      "bbox": [
        114.92,
        334.96,
        278.07,
        346.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 2
    },
    {
      "span_id": "p105_s0012",
      "text": "  The Alias Group Identifier field contains the Alias_ID that",
      "bbox": [
        277.98,
        334.96,
        540.12,
        346.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p105_s0013",
      "text": "the Nx_Port shall recognize, in addition to its native address identifier.",
      "bbox": [
        122.4,
        346.96,
        430.65,
        358.08
      ],
      "block_index": 4,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p105_s0014",
      "text": "c)",
      "bbox": [
        106.02,
        370.96,
        114.38,
        382.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0015",
      "text": "Alias Group Service Parameters (Alias_SP):",
      "bbox": [
        122.4,
        370.96,
        331.86,
        382.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p105_s0016",
      "text": " The Alias_SP defines the Service Parameters",
      "bbox": [
        331.86,
        370.96,
        540.12,
        382.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 2
    },
    {
      "span_id": "p105_s0017",
      "text": "to be used for all operations with this Alias Group (see FC-FS-2).",
      "bbox": [
        122.4,
        382.96,
        409.14,
        394.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
      "span_id": "p105_s0018",
      "text": "NOTE 6 – These Service Parameters may differ from those passed during Login.",
      "bbox": [
        105.0,
        407.18,
        426.71,
        417.22
      ],
      "block_index": 6,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0019",
      "text": "For Multicast Groups, only the Common Service Parameters and Class 3 Service Parameters",
      "bbox": [
        122.4,
        430.97,
        540.04,
        442.08
      ],
      "block_index": 7,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0020",
      "text": "are used.  For Hunt Groups, all Service Parameters may be used.",
      "bbox": [
        122.4,
        442.97,
        412.85,
        454.08
      ],
      "block_index": 7,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p105_s0021",
      "text": "The Nx_Port shall transmit a LS_ACC to notify the Alias Server if the Nx_Port:",
      "bbox": [
        96.0,
        466.97,
        441.03,
        478.08
      ],
      "block_index": 8,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0022",
      "text": "a) Supports the Alias_Class in the Alias_Token.",
      "bbox": [
        106.02,
        490.97,
        321.74,
        502.08
      ],
      "block_index": 9,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0023",
      "text": "b) Supports the Alias Group Service Parameters specified in Alias_SP.",
      "bbox": [
        106.02,
        514.96,
        423.41,
        526.08
      ],
      "block_index": 10,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0024",
      "text": "c)",
      "bbox": [
        106.02,
        538.96,
        114.35,
        550.08
      ],
      "block_index": 11,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p105_s0025",
      "text": "Has assigned the passed Alias_ID as an Alias_ID for this Nx_Port.",
      "bbox": [
        122.37,
        538.96,
        416.25,
        550.08
      ],
      "block_index": 11,
      "line_index": 2,
      "span_index": 1
    },
