      "block_index": 5,
      "line_index": 1,
      "span_index": 3
    },
    {
      "span_id": "p063_s0010",
      "text": "tected the Loop Failure.  This field is valid only if the Loop State indicates a Loop Failure.  This",
      "bbox": [
        122.4,
        394.96,
        540.15,
        406.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p063_s0011",
      "text": "field shall be set to 00h if the FL_Port detected the failure.  This field shall be set to F7h if the",
      "bbox": [
        122.4,
        406.96,
        540.02,
        418.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
