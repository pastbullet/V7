    {
      "span_id": "p075_s0005",
      "text": "4.2.21.1  Description",
      "bbox": [
        96.0,
        82.97,
        192.63,
        94.08
      ],
      "block_index": 4,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p075_s0006",
      "text": "The PRLO ELS is used to request invalidation of the operating environment between an image at the",
      "bbox": [
        96.0,
        106.97,
        539.97,
        118.08
      ],
      "block_index": 5,
      "line_index": 1,
      "span_index": 1
    },
    {
      "span_id": "p075_s0007",
      "text": "initiating Nx_Port and an image at the recipient Nx_Port.  PRLO frees resources committed by a pre-",
      "bbox": [
        96.0,
        118.97,
        539.96,
        130.08
      ],
      "block_index": 5,
      "line_index": 2,
      "span_index": 1
    },
    {
      "span_id": "p075_s0008",
      "text": "vious PRLI function (see 7.2).",
      "bbox": [
        96.0,
        130.97,
        227.14,
        142.08
      ],
      "block_index": 5,
      "line_index": 3,
      "span_index": 1
    },
    {
