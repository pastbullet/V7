{"cell_id": "r8c4", "row": 8, "col": 4, "text": "The N_Port specified in the RCS frame is not\nfunctioning in Intermix mode.", "page": 52, "bbox": [318.69, 420.03, 537.31, 454.05]}
{"cell_id": "r9c1", "row": 9, "col": 1, "text": "", "page": 52, "bbox": [0.0, 0.0, 0.0, 0.0]}
