{"cell_id": "r6c4", "row": 6, "col": 4, "text": "The specified Nx_Port in the RCS Request is not\nin a dedicated connection", "page": 52, "bbox": [318.69, 328.05, 537.31, 362.01]}
{"cell_id": "r7c1", "row": 7, "col": 1, "text": "", "page": 52, "bbox": [0.0, 0.0, 0.0, 0.0]}
