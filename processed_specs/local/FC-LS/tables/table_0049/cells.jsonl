{"cell_id": "r4c1", "row": 4, "col": 1, "text": "0010b", "page": 74, "bbox": [105.26, 349.35, 192.27, 395.37]}
{"cell_id": "r4c2", "row": 4, "col": 2, "text": "The Exchange recipient has no resources available for establishing image\npairs between the specified source and destination Nx_Ports. The PRLI\nRequest may be retried.", "page": 74, "bbox": [192.27, 349.35, 530.74, 395.37]}
{"cell_id": "r5c1", "row": 5, "col": 1, "text": "0011b", "page": 74, "bbox": [105.26, 395.37, 192.27, 429.39]}
{"cell_id": "r5c2", "row": 5, "col": 2, "text": "Initialization is not complete for the Exchange recipient. The PRLI Request\nmay be retried.", "page": 74, "bbox": [192.27, 395.37, 530.74, 429.39]}
{"cell_id": "r6c1", "row": 6, "col": 1, "text": "0100b", "page": 74, "bbox": [105.26, 429.39, 192.27, 475.35]}
{"cell_id": "r6c2", "row": 6, "col": 2, "text": "The Exchange recipient corresponding to the Responder\nProcess_Associator specified in the PRLI Request and PRLI LS_ACC\nresponse does not exist. The PRLI Request shall not be retried.", "page": 74, "bbox": [192.27, 429.39, 530.74, 475.35]}
{"cell_id": "r7c1", "row": 7, "col": 1, "text": "0101b", "page": 74, "bbox": [105.26, 475.35, 192.27, 509.37]}
{"cell_id": "r7c2", "row": 7, "col": 2, "text": "The Exchange recipient has a predefined configuration that precludes\nestablishing this image pair. The PRLI Request shall not be retried.", "page": 74, "bbox": [192.27, 475.35, 530.74, 509.37]}
{"cell_id": "r8c1", "row": 8, "col": 1, "text": "0110b", "page": 74, "bbox": [105.26, 509.37, 192.27, 543.39]}
