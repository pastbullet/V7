    {
      "unit_id": "login-explicit-overview",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p152_s0019",
          "quote": "Explicit Login is accomplished using a Login (FLOGI or PLOGI) ELS"
        },
        {
          "type": "text_span",
          "span_id": "p152_s0021",
          "quote": "The LS_ACC contains the Service Parameters of the Responder"
        }
      ],
      "related_assets": []
    },
    {
      "unit_id": "fabric-login-request",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p153_s0033",
          "quote": "The Nx_Port shall transmit the FLOGI in a new Exchange."
        },
        {
          "type": "text_span",
          "span_id": "p153_s0036",
          "quote": "The Nx_Port shall assign an OX_ID and"
        },
        {
          "type": "text_span",
          "span_id": "p153_s0037",
          "quote": "set the D_ID to the well-known F_Port address (i.e., FFFFFEh)."
        }
      ],
      "related_assets": []
    },
    {
      "unit_id": "fabric-login-response-branches",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p154_s0003",
          "quote": "Responses to Explicit Fabric Login"
        },
        {
          "type": "text_span",
          "span_id": "p154_s0005",
          "quote": "LS_ACC reply Sequence"
        },
        {
          "type": "text_span",
          "span_id": "p154_s0016",
          "quote": "LS_ACC reply Sequence with OX_ID equal to the OX_ID of the FLOGI, and the Common Ser"
        },
        {
          "type": "text_span",
          "span_id": "p154_s0025",
          "quote": "F_BSY with OX_ID equal to the OX_ID of the FLOGI."
        },
        {
          "type": "text_span",
          "span_id": "p154_s0027",
          "quote": "P_BSY Sequence with OX_ID equal to the OX_ID of the FLOGI."
        },
        {
          "type": "text_span",
          "span_id": "p154_s0031",
          "quote": "F_RJT Sequence with OX_ID equal to the OX_ID of the FLOGI."
        },
        {
          "type": "text_span",
          "span_id": "p154_s0043",
          "quote": "P_RJT Sequence, with OX_ID equal to the OX_ID of the FLOGI."
        },
        {
          "type": "text_span",
          "span_id": "p155_s0003",
          "quote": "LS_RJT Sequence with OX_ID equal to the OX_ID of the FLOGI."
        },
        {
          "type": "text_span",
          "span_id": "p155_s0009",
          "quote": "No Response may indicate a delivery error"
        },
        {
          "type": "text_span",
          "span_id": "p155_s0013",
          "quote": "If the received N_Port_Name is equal to its N_Port_Name"
        }
      ],
      "related_assets": []
    },
    {
      "unit_id": "fabric-relogin-change-handling",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p155_s0025",
          "quote": "Relogin with the Fabric"
        },
        {
          "type": "text_span",
          "span_id": "p155_s0029",
          "quote": "Nx_Port detects that the N_Port_ID, F_Port_Name, and/or the Fabric_Name has changed"
        },
        {
          "type": "text_span",
          "span_id": "p155_s0030",
          "quote": "the Nx_Port shall implicitly logout with all Nx_Ports and wait an R_A_TOV timeout"
        },
        {
          "type": "text_span",
          "span_id": "p155_s0032",
          "quote": "After waiting the timeout period, new N_Port Logins are"
        },
        {
          "type": "text_span",
          "span_id": "p155_s0033",
          "quote": "required before the Nx_Port may communicate with other Nx_Ports."
        }
      ],
      "related_assets": []
    },
    {
      "unit_id": "nport-login-request-fabric-present",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p156_s0044",
          "quote": "N_Port Login follows the Fabric Login procedure."
        },
        {
          "type": "text_span",
          "span_id": "p158_s0022",
          "quote": "The destination Nx_Port explicit Login procedure requires transmission of a N_Port Login (PLOGI)"
        },
        {
          "type": "text_span",
          "span_id": "p158_s0023",
          "quote": "Link Service Sequence.  The PLOGI is sent within an Exchange with an assigned OX_ID"
        }
      ],
      "related_assets": []
    },
