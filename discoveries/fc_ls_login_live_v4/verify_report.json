    {
      "unit_id": "prli-overview",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p197_s0009",
          "quote": "The Process Login (PRLI) ELS request shall be used to establish the operating environment"
        },
        {
          "type": "text_span",
          "span_id": "p198_s0004",
          "quote": "PRLI, if required, is performed after N_Port Login is successful and prior to other FC-4 transfers."
        },
        {
          "type": "text_span",
          "span_id": "p198_s0014",
          "quote": "An image pair may be established or modified with a PRLI request and LS_ACC reply Sequence set."
        }
      ],
      "related_assets": []
    },
    {
      "unit_id": "prli-response-handling",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p199_s0003",
          "quote": "The Nx_Port originating the PRLI request shall not consider the image pair to be established until it"
        },
        {
          "type": "text_span",
          "span_id": "p199_s0006",
          "quote": "quest does not consider the image pair to be established until the necessary action is taken at the"
        },
        {
          "type": "text_span",
          "span_id": "p199_s0010",
          "quote": "it shall reply with a LOGO ELS Sequence, or with an LS_RJT ELS Sequence"
        },
        {
          "type": "text_span",
          "span_id": "p199_s0011",
          "quote": "\"Unable to perform command request\" and a reason code explanation of \"N_Port Login required\"."
        },
        {
          "type": "text_span",
          "span_id": "p199_s0013",
          "quote": "If an LS_RJT, P_BSY, F_BSY, P_RJT, or F_RJT response is re"
        },
        {
          "type": "text_span",
          "span_id": "p199_s0014",
          "quote": "ceived to a PRLI request, the PRLI request may be retried until the image pair is established."
        },
        {
          "type": "text_span",
          "span_id": "p199_s0018",
          "quote": "shall not assume that the requested action has or has not taken place. If the Nx_Port that originates"
        },
        {
          "type": "text_span",
          "span_id": "p199_s0019",
          "quote": "a PRLI request receives no valid response, the Nx_Port should retry the request."
        }
      ],
      "related_assets": []
    },
