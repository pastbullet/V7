    {
      "claim_id": "flogi_plogi_lsacc_large_login_step1",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p165_s0007",
          "quote": "If a Login of 256 bytes or more is required when the buffer conditions of the destination port are un-"
        },
        {
          "type": "text_span",
          "span_id": "p165_s0008",
          "quote": "known, a timeout may be avoided with the following procedure:"
        },
        {
          "type": "text_span",
          "span_id": "p165_s0009",
          "quote": "1) issue a Login request with the Payload Bit (see 6.6.2.4.19) set to zero;"
        }
      ]
    },
    {
      "claim_id": "flogi_plogi_lsacc_large_login_step2",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p165_s0010",
          "quote": "2) if the Query Buffer Conditions bit (see 6.6.2.4.14) is set to one in the LS_ACC, issue an RPBC"
        },
        {
          "type": "text_span",
          "span_id": "p165_s0011",
          "quote": "ELS (see 4.2.37); and"
        }
      ]
    },
    {
      "claim_id": "flogi_plogi_lsacc_large_login_step3",
      "evidence_refs": [
        {
          "type": "text_span",
          "span_id": "p165_s0012",
          "quote": "3) if both the ELS Receive Data Field Size field in the RPBC LS_ACC Payload and the Buffer-to-"
        },
        {
          "type": "text_span",
          "span_id": "p165_s0013",
          "quote": "buffer Receive Data_Field Size field in the Login LS_ACC Payload are at least 256 bytes, issue"
        },
        {
          "type": "text_span",
          "span_id": "p165_s0014",
          "quote": "a Login request with the Payload Bit set to one."
        }
      ]
    }
