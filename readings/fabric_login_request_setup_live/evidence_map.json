    {
      "type": "text_span",
      "span_id": "p153_s0008",
      "quote": "with other Nx_Ports shall not be attempted until the Fabric Login procedure is complete."
    }
  ],
  "fabric_login_request_setup_c2": [
    {
      "type": "text_span",
      "span_id": "p153_s0033",
      "quote": "The Nx_Port shall transmit the FLOGI in a new Exchange."
    }
  ],
  "fabric_login_request_setup_c3": [
    {
      "type": "text_span",
      "span_id": "p153_s0033",
      "quote": "The Payload of FLOGI contains the Ser-"
    },
    {
      "type": "text_span",
      "span_id": "p153_s0034",
      "quote": "vice Parameters of the Nx_Port, a 64-bit N_Port_Name of the Nx_Port, and a 64-bit Node_Name."
    }
  ],
  "fabric_login_request_setup_c4": [
    {
      "type": "text_span",
      "span_id": "p153_s0034",
      "quote": "vice Parameters of the Nx_Port, a 64-bit N_Port_Name of the Nx_Port, and a 64-bit Node_Name."
    }
