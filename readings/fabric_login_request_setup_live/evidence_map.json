  "fabric_login_request_setup_c16": [
    {
      "type": "text_span",
      "span_id": "p153_s0036",
      "quote": "rameters to Fabric Login are given in tables 150 and 155.  The Nx_Port shall assign an OX_ID and"
    }
  ],
  "fabric_login_request_setup_c17": [
    {
      "type": "text_span",
      "span_id": "p153_s0037",
      "quote": "set the D_ID to the well-known F_Port address (i.e., FFFFFEh)."
    }
  ],
  "fabric_login_request_setup_c18": [
    {
      "type": "text_span",
      "span_id": "p153_s0038",
      "quote": "If the Nx_Port is unidentified, an Nx_Port shall set the S_ID in the FLOGI to 000000h or 0000h || YY."
    }
  ],
  "fabric_login_request_setup_c19": [
    {
      "type": "text_span",
      "span_id": "p153_s0039",
      "quote": "If the Nx_Port sets the S_ID to 000000h, the Nx_Port is requesting the Fabric assign all 24 bits of the"
    },
    {
      "type": "text_span",
      "span_id": "p153_s0040",
      "quote": "N_Port_ID."
    }
  ],
  "fabric_login_request_setup_c20": [
    {
      "type": "text_span",
      "span_id": "p153_s0040",
      "quote": "If the Nx_Port sets the S_ID to 0000h || YY, the Nx_Port is requesting the Fabric assign"
    },
    {
      "type": "text_span",
      "span_id": "p153_s0041",
      "quote": "the upper 16 bits, bits 23 to 8, and validate the lower 8 bits, bits 7 to 0, of the N_Port_ID."
    }
  ],
  "fabric_login_request_setup_c21": [
    {
      "type": "text_span",
      "span_id": "p153_s0041",
      "quote": "the upper 16 bits, bits 23 to 8, and validate the lower 8 bits, bits 7 to 0, of the N_Port_ID."
    }
  ]
